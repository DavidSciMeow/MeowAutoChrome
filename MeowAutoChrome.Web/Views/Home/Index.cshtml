@{
    ViewData["Title"] = "浏览器控制台";
    Layout = "_Layout";
}

<div class="browser-workspace" id="browserWorkspace">
    <!-- Toast container (top-right floating) -->
    <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:10800;"></div>
    <div class="browser-pane browser-pane-left">
        <div class="browser-control-panel mb-3">
            <div class="browser-chrome">
                <div class="browser-tabstrip-meta">
                    <div class="browser-tabs-shell" id="tabsShell">
                        <button type="button" class="btn btn-sm btn-outline-secondary browser-chrome-icon-btn" id="tabsScrollLeftBtn" title="向左滚动" aria-label="向左滚动">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <div id="tabsBar" class="browser-tabs"></div>
                        <button type="button" class="btn btn-sm btn-outline-secondary browser-chrome-icon-btn" id="tabsScrollRightBtn" title="向右滚动" aria-label="向右滚动">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                        <!-- newInstanceBtn moved into toolbar for clearer placement -->
                    </div>
                    <div class="browser-tabstrip-controls">
                        <button type="button" class="btn btn-sm btn-primary browser-live-toggle" id="liveToggleBtn">实时画面</button>
                        <small class="browser-tabstrip-metric" id="cpuDisplay">CPU --</small>
                        <small class="browser-tabstrip-metric" id="memoryDisplay">RAM --</small>
                        <small class="browser-tabstrip-metric" id="fpsDisplay">FPS --</small>
                        <span id="connStatus" class="badge bg-secondary">未连接</span>
                        <span id="instanceStatus" class="badge bg-danger d-none ms-2">无实例</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary ms-2" id="headlessToggleBtn" title="切换 Headless 模式">
                            <i class="fa-solid fa-eye-slash me-1"></i>
                            <span id="headlessBadge" class="badge bg-secondary">Headless</span>
                        </button>
                    </div>
                </div>

                <div class="browser-toolbar">
                    <div class="browser-toolbar-group">
                        <button type="button" class="btn btn-outline-secondary browser-chrome-icon-btn" id="backBtn" title="Back" aria-label="Back"><i class="fa-solid fa-arrow-left"></i></button>
                        <button type="button" class="btn btn-outline-secondary browser-chrome-icon-btn" id="forwardBtn" title="Forward" aria-label="Forward"><i class="fa-solid fa-arrow-right"></i></button>
                        <button type="button" class="btn btn-outline-secondary browser-chrome-icon-btn" id="reloadBtn" title="Reload" aria-label="Reload"><i class="fa-solid fa-rotate-right"></i></button>
                    </div>

                    <div class="browser-omnibox">
                        <span class="browser-omnibox-icon"><i class="fa-solid fa-globe"></i></span>
                        <input id="urlInput" class="form-control" placeholder="输入地址，例如 https://example.com" />
                        <button type="button" class="btn btn-primary browser-omnibox-go" id="goBtn" title="Go" aria-label="Go"><i class="fa-solid fa-up-right-from-square"></i></button>
                    </div>

                    <div class="browser-toolbar-group">
                        <button type="button" class="btn btn-outline-primary browser-chrome-icon-btn" id="shotBtn" title="Screenshot" aria-label="Screenshot"><i class="fa-solid fa-camera"></i></button>
                        <button type="button" class="btn btn-primary btn-md ms-2" id="newInstanceBtn" title="新建实例" aria-label="新建实例" style="font-weight:600;padding:.35rem .85rem"><i class="fa-solid fa-plus me-1"></i>新建实例</button>
                    </div>
                </div>

                <div id="browserError" class="alert alert-warning d-none mt-3 mb-0" role="alert"></div>
            </div>
        </div>

        <div class="browser-stage">
            <canvas id="browserCanvas"
                    tabindex="0">
            </canvas>
            <div id="tabsStatusPanel" class="tabs-status-panel d-none"></div>
            <div id="noSignal"
                 style="position:absolute;inset:0;display:flex;align-items:center;
                        justify-content:center;color:#555;font-size:1.2rem;">
                等待画面...
            </div>
        </div>
    </div>

<div class="modal fade" id="instanceSettingsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="instanceSettingsModalTitle">实例设置</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="instanceSettingsModalSummary" class="text-muted small mb-3"></div>
                <input type="hidden" id="instanceSettingsInstanceId" />
                <input type="hidden" id="instanceSettingsCurrentUserDataDirectory" />
                <input type="hidden" id="instanceSettingsIsSelected" />

                <div class="mb-3">
                    <label class="form-label" for="instanceUserDataDirectoryInput">UserData 目录</label>
                    <input type="text" class="form-control" id="instanceUserDataDirectoryInput" placeholder="输入浏览器 UserData 目录" />
                    <div class="form-text">切换目录时会询问是否把旧目录一起迁移过去。</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="instanceUserAgentInput">实例 User-Agent</label>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="instanceUseProgramUserAgentInput" />
                        <label class="form-check-label" for="instanceUseProgramUserAgentInput">跟随程序设置 User-Agent</label>
                    </div>
                    <input type="text" class="form-control" id="instanceUserAgentInput" placeholder="留空时使用浏览器默认 User-Agent" />
                    <div id="instanceUserAgentProgramHint" class="form-text">程序设置 UA：未设置</div>
                    <div id="instanceUserAgentEffectiveHint" class="form-text">当前生效 UA：浏览器默认</div>
                    <div id="instanceUserAgentLockHint" class="form-text text-warning d-none">程序设置已锁定全局 UA，当前实例不能覆盖。</div>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-sm-6">
                        <label class="form-label" for="instanceViewportWidthInput">默认宽度</label>
                        <input type="number" min="320" step="1" class="form-control" id="instanceViewportWidthInput" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label" for="instanceViewportHeightInput">默认高度</label>
                        <input type="number" min="240" step="1" class="form-control" id="instanceViewportHeightInput" />
                    </div>
                </div>

                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="instancePreserveAspectRatioInput" />
                    <label class="form-check-label" for="instancePreserveAspectRatioInput">跟随时保持宽高比</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="instanceAutoResizeViewportInput" />
                    <label class="form-check-label" for="instanceAutoResizeViewportInput">跟随浏览器区域大小自动调整网页尺寸</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="instanceSettingsSubmitBtn">保存</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createInstanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg" style="max-width:920px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">新建实例</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label" for="createInstanceDisplayName">实例显示名（可选）</label>
                    <input id="createInstanceDisplayName" class="form-control" placeholder="留空使用默认名" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="createInstanceUserDataDirectory">UserData 目录（可选）</label>
                    <input id="createInstanceUserDataDirectory" class="form-control" placeholder="留空使用默认目录" />
                    <div class="form-text">指定用户数据目录可为每个实例指定独立配置。</div>
                </div>
                <div id="createInstancePathTooltip" class="small bg-light border rounded p-2" style="display:none; position:relative; z-index:20000; max-width:880px;">
                    <div class="create-path-text" aria-live="polite"></div>
                    <button type="button" class="btn btn-sm btn-outline-secondary create-path-copy-btn" title="复制路径">
                        <i class="fa-regular fa-copy"></i>
                    </button>
                </div>
                <input type="hidden" id="createInstanceOwnerPluginId" value="ui" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="createInstanceSubmitBtn">创建</button>
            </div>
        </div>
    </div>
</div>
    <div class="browser-pane-divider" id="browserPaneDivider" role="separator" aria-orientation="vertical" aria-label="调整浏览器区与插件区宽度" tabindex="0"></div>
    <div class="browser-pane browser-pane-right">
        <div class="card h-100 plugin-panel">
            <div class="card-header">插件区</div>
            <div class="card-body">
                <div id="pluginHost" class="vstack gap-3 small text-muted"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pluginArgumentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="pluginArgumentModalTitle">插件参数</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="pluginArgumentModalDescription" class="text-muted small mb-3 d-none"></div>
                <div id="pluginArgumentForm" class="vstack gap-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="pluginArgumentSubmitBtn">执行</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="pluginOutputModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="pluginOutputModalTitle">插件输出</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="pluginOutputModalSummary" class="text-muted small mb-3 d-none"></div>
                <div class="border rounded p-3 bg-light-subtle mb-3">
                    <div class="fw-semibold small mb-2">当前返回值</div>
                    <div id="pluginOutputModalData" class="vstack gap-2 small"></div>
                </div>
                <div class="fw-semibold small mb-2">输出时间线</div>
                <div id="pluginOutputModalEntries" class="vstack gap-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">关闭</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="screenshotPreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">截图预览</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center bg-dark-subtle">
                <img id="screenshotPreviewImage" class="img-fluid rounded" alt="截图预览" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/browser-index.js" asp-append-version="true"></script>
    <script src="~/js/browser-ui.js" asp-append-version="true"></script>
    <script src="~/js/browser-input.js" asp-append-version="true"></script>
    <script src="~/js/browser-plugins.js" asp-append-version="true"></script>
    <script src="~/js/browser-tabs.js" asp-append-version="true"></script>
    <script>
        (function () {
            // expose server-side settings into window.__browserConfig for the static modules
            window.__browserConfig = {
                defaultPluginPanelWidth: @ProgramSettings.DefaultPluginPanelWidth,
                minPluginPanelWidth: @ProgramSettings.MinPluginPanelWidth,
                maxPluginPanelWidth: @ProgramSettings.MaxPluginPanelWidth
            };

            // Centralized, overridable API endpoints used by front-end JS.
            // Can be customized here or via server-side config if needed.
            window.__apiEndpoints = window.__apiEndpoints || {
                status: '/api/status',
                plugins: '/api/plugins',
                pluginsControl: '/api/plugins/control',
                pluginsRun: '/api/plugins/run',
                tabsClose: '/api/tabs/close',
                tabsSelect: '/api/tabs/select',
                tabsNew: '/api/tabs/new',
                instances: '/api/instances',
                instancesClose: '/api/instances/close',
                instancesSettings: '/api/instances/settings',
                screencastSettings: '/api/screencast/settings',
                screenshot: '/api/screenshot',
                navigation: '/api/navigation/navigate',
                layout: '/api/layout',
                logsContent: '/api/logs/content',
                logsClear: '/api/logs/clear'
            };
            const canvas = document.getElementById("browserCanvas");
            const ctx    = canvas.getContext("2d");
            const browserStage = canvas.closest(".browser-stage");
            const browserWorkspace = document.getElementById("browserWorkspace");
            const browserPaneDivider = document.getElementById("browserPaneDivider");
            const status = document.getElementById("connStatus");
            const noSig  = document.getElementById("noSignal");
            const cpuTxt = document.getElementById("cpuDisplay");
            const memoryTxt = document.getElementById("memoryDisplay");
            const fpsTxt = document.getElementById("fpsDisplay");
            const browserError = document.getElementById("browserError");
            const urlInput = document.getElementById("urlInput");
            const tabsBar = document.getElementById("tabsBar");
            const tabsShell = document.getElementById("tabsShell");
            const tabsScrollLeftBtn = document.getElementById("tabsScrollLeftBtn");
            const tabsScrollRightBtn = document.getElementById("tabsScrollRightBtn");
            const newInstanceBtn = document.getElementById("newInstanceBtn");
            const liveToggleBtn = document.getElementById("liveToggleBtn");
            const tabsStatusPanel = document.getElementById("tabsStatusPanel");
            const pluginHost = document.getElementById("pluginHost");
            const pluginArgumentModalElement = document.getElementById("pluginArgumentModal");
            const screenshotPreviewModalElement = document.getElementById("screenshotPreviewModal");
            const pluginOutputModalElement = document.getElementById("pluginOutputModal");
            const instanceSettingsModalElement = document.getElementById("instanceSettingsModal");
            const screenshotPreviewImage = document.getElementById("screenshotPreviewImage");
            const pluginArgumentModalTitle = document.getElementById("pluginArgumentModalTitle");
            const pluginArgumentModalDescription = document.getElementById("pluginArgumentModalDescription");
            const pluginArgumentForm = document.getElementById("pluginArgumentForm");
            const pluginArgumentSubmitBtn = document.getElementById("pluginArgumentSubmitBtn");
            const pluginOutputModalTitle = document.getElementById("pluginOutputModalTitle");
            const pluginOutputModalSummary = document.getElementById("pluginOutputModalSummary");
            const pluginOutputModalData = document.getElementById("pluginOutputModalData");
            const pluginOutputModalEntries = document.getElementById("pluginOutputModalEntries");
            const instanceSettingsModalTitle = document.getElementById("instanceSettingsModalTitle");
            const instanceSettingsModalSummary = document.getElementById("instanceSettingsModalSummary");
            const instanceSettingsInstanceIdInput = document.getElementById("instanceSettingsInstanceId");
            const instanceSettingsCurrentUserDataDirectoryInput = document.getElementById("instanceSettingsCurrentUserDataDirectory");
            const instanceSettingsIsSelectedInput = document.getElementById("instanceSettingsIsSelected");
            const instanceUserDataDirectoryInput = document.getElementById("instanceUserDataDirectoryInput");
            const instanceUseProgramUserAgentInput = document.getElementById("instanceUseProgramUserAgentInput");
            const instanceUserAgentInput = document.getElementById("instanceUserAgentInput");
            const instanceUserAgentProgramHint = document.getElementById("instanceUserAgentProgramHint");
            const instanceUserAgentEffectiveHint = document.getElementById("instanceUserAgentEffectiveHint");
            const instanceUserAgentLockHint = document.getElementById("instanceUserAgentLockHint");
            const instanceViewportWidthInput = document.getElementById("instanceViewportWidthInput");
            const instanceViewportHeightInput = document.getElementById("instanceViewportHeightInput");
            const instancePreserveAspectRatioInput = document.getElementById("instancePreserveAspectRatioInput");
            const instanceAutoResizeViewportInput = document.getElementById("instanceAutoResizeViewportInput");
            const instanceSettingsSubmitBtn = document.getElementById("instanceSettingsSubmitBtn");
            const shotBtn = document.getElementById("shotBtn");
            const instanceStatusBadge = document.getElementById("instanceStatus");
            const pluginArgumentModal = pluginArgumentModalElement ? new bootstrap.Modal(pluginArgumentModalElement) : null;
            const screenshotPreviewModal = screenshotPreviewModalElement ? new bootstrap.Modal(screenshotPreviewModalElement) : null;
            const pluginOutputModal = pluginOutputModalElement ? new bootstrap.Modal(pluginOutputModalElement) : null;
            const instanceSettingsModal = instanceSettingsModalElement ? new bootstrap.Modal(instanceSettingsModalElement) : null;
            const pluginCatalog = new Map();
            const pluginOutputStore = new Map();
            const pluginOutputUi = new Map();
            let statusBusy = false;
            const shownMessages = new Set();
            let isEditingUrl = false;
            let liveDisplayEnabled = true;
            let measuredFps = 0;
            let targetFrameIntervalMs = 100;
            let resizeSyncTimer = null;
            let applyingScreencastSettings = false;
            let pendingScreencastSync = false;
            let screencastAvailable = true;
            let pluginPanelWidth = @ProgramSettings.DefaultPluginPanelWidth;
            let pointerResizeActive = false;
            let pendingPluginInvocation = null;
            let activePluginOutputPluginId = null;
            let browserHubConnectionId = null;
            let screenshotPreviewUrl = null;
            let selectedInstanceId = null;
            let currentInstanceViewport = null;
            let instanceViewportSyncTimer = null;
            let applyingInstanceViewportSync = false;
            let pendingInstanceViewportSync = false;
            let instanceSettingsAspectRatio = null;
            let synchronizingAspectRatio = false;
            let canvasKeyboardCaptureActive = false;

            function clampPluginPanelWidth(width) {
                const workspaceWidth = Math.max(0, browserWorkspace?.clientWidth || 0);
                const maxAllowedByWorkspace = workspaceWidth > 0
                    ? Math.max(@ProgramSettings.MinPluginPanelWidth, workspaceWidth - 360)
                    : @ProgramSettings.MaxPluginPanelWidth;
                const hardMax = Math.min(@ProgramSettings.MaxPluginPanelWidth, maxAllowedByWorkspace);
                return Math.max(@ProgramSettings.MinPluginPanelWidth, Math.min(hardMax, Math.round(Number(width) || @ProgramSettings.DefaultPluginPanelWidth)));
            }

            function applyPluginPanelWidth(width) {
                pluginPanelWidth = clampPluginPanelWidth(width);
                document.documentElement.style.setProperty("--plugin-panel-width", pluginPanelWidth + "px");
            }

            async function savePluginPanelWidth(width) {
                try {
                    const result = await postJson('layout', { pluginPanelWidth: clampPluginPanelWidth(width) });
                    applyPluginPanelWidth(result.pluginPanelWidth);
                } catch (e) {
                    showError(e.message || "布局保存失败。");
                }
            }

            function beginPanelResize() {
                if (window.matchMedia("(max-width: 1199.98px)").matches)
                    return false;

                pointerResizeActive = true;
                browserWorkspace.classList.add("browser-workspace-resizing");
                return true;
            }

            function updatePanelResize(clientX) {
                if (!pointerResizeActive || !browserWorkspace)
                    return;

                const rect = browserWorkspace.getBoundingClientRect();
                applyPluginPanelWidth(rect.right - clientX);
            }

            function endPanelResize(shouldPersist = true) {
                if (!pointerResizeActive)
                    return;

                pointerResizeActive = false;
                browserWorkspace.classList.remove("browser-workspace-resizing");
                if (shouldPersist)
                    savePluginPanelWidth(pluginPanelWidth).catch(() => { });
            }

            // ── FPS 计数 ──────────────────────────────────────────────
            let frameCount = 0, lastFpsTime = performance.now();
            function renderFpsDisplay() {
                fpsTxt.textContent = "FPS " + measuredFps + " / " + intervalToFps(targetFrameIntervalMs);
            }

            function renderResourceMetrics(data) {
                cpuTxt.textContent = "CPU " + Number(data.cpuUsagePercent || 0).toFixed(1) + "%";
                memoryTxt.textContent = "RAM " + Number(data.memoryUsageMb || 0).toFixed(1) + " MB";
            }

            function updateFps() {
                frameCount++;
                const now = performance.now();
                if (now - lastFpsTime >= 1000) {
                    measuredFps = frameCount;
                    renderFpsDisplay();
                    frameCount = 0;
                    lastFpsTime = now;
                }
            }

            // ── 渲染队列 ──────────────────────────────────────────────
            const img   = new Image();
            let pending = null, busy = false, activeFrame = null;

            img.onload = function () {
                const viewport = getCanvasViewportSize();
                const targetWidth = canvas.width || viewport.width;
                const targetHeight = canvas.height || viewport.height;
                const sourceWidth = activeFrame?.width ?? img.naturalWidth;
                const sourceHeight = activeFrame?.height ?? img.naturalHeight;

                resizeCanvasBuffer(targetWidth, targetHeight);
                ctx.fillStyle = "#000";
                ctx.fillRect(0, 0, targetWidth, targetHeight);

                const scale = Math.min(targetWidth / Math.max(1, sourceWidth), targetHeight / Math.max(1, sourceHeight));
                const drawWidth = Math.max(1, Math.round(sourceWidth * scale));
                const drawHeight = Math.max(1, Math.round(sourceHeight * scale));
                const offsetX = Math.floor((targetWidth - drawWidth) / 2);
                const offsetY = Math.floor((targetHeight - drawHeight) / 2);

                ctx.drawImage(img, offsetX, offsetY, drawWidth, drawHeight);
                noSig.style.display = "none";
                updateFps();
                busy = false;
                if (pending !== null) { const n = pending; pending = null; drawFrame(n); }
            };

            function drawFrame(frame) {
                if (busy) { pending = frame; return; }
                busy = true;
                activeFrame = frame;
                img.src = "data:image/jpeg;base64," + frame.data;
            }

            // ── SignalR ───────────────────────────────────────────────
            const conn = new signalR.HubConnectionBuilder()
                .withUrl("/browserHub")
                .withAutomaticReconnect()
                .build();

            conn.on("ReceiveFrame", drawFrame);
            conn.on("ScreencastDisabled", () => {
                noSig.textContent = "实时画面已关闭";
                noSig.style.display = "flex";
            });

            conn.on("ReceivePluginOutput", update => {
                applyPluginOutputUpdate(update);
            });

            conn.onreconnecting(() => { status.textContent = "重连中..."; status.className = "badge bg-warning text-dark"; });
            conn.onreconnected(connectionId  => {
                browserHubConnectionId = connectionId || conn.connectionId || null;
                if (window.BrowserIndex) window.BrowserIndex.browserHubConnectionId = browserHubConnectionId;
                status.textContent = "已连接";
                status.className = "badge bg-success";
                // setup headless toggle UI handlers after reconnect
                try { setupHeadlessToggle(); } catch (e) { }
            });

            // start SignalR connection and initialize UI handlers/status
            (async () => {
                try {
                    await conn.start();
                    browserHubConnectionId = conn.connectionId || null;
                    status.textContent = "已连接";
                    status.className = "badge bg-success";
                    try { setupHeadlessToggle(); } catch (e) { }
                    try { await refreshStatus(); } catch (e) { }
                } catch (e) {
                    console.error('SignalR start failed', e);
                    status.textContent = '未连接';
                    status.className = 'badge bg-secondary';
                }
            })();

            function setupHeadlessToggle() {
                const headlessToggleBtn = document.getElementById('headlessToggleBtn');
                const headlessConfirmModalEl = document.getElementById('headlessConfirmModal');
                const headlessConfirmModal = headlessConfirmModalEl ? new bootstrap.Modal(headlessConfirmModalEl) : null;
                const headlessConfirmSubmitBtn = document.getElementById('headlessConfirmSubmitBtn');
                const headlessConfirmProgress = document.getElementById('headlessConfirmProgress');

                if (!headlessToggleBtn || !headlessConfirmModal || !headlessConfirmSubmitBtn) return;

                // avoid multiple event bindings
                headlessToggleBtn.replaceWith(headlessToggleBtn.cloneNode(true));
                const newToggle = document.getElementById('headlessToggleBtn');
                newToggle.addEventListener('click', () => {
                    headlessConfirmProgress.classList.add('d-none');
                    headlessConfirmSubmitBtn.disabled = false;
                    headlessConfirmModal.show();
                });

                headlessConfirmSubmitBtn.replaceWith(headlessConfirmSubmitBtn.cloneNode(true));
                const newSubmit = document.getElementById('headlessConfirmSubmitBtn');
                newSubmit.addEventListener('click', async () => {
                    newSubmit.disabled = true;
                    headlessConfirmProgress.classList.remove('d-none');
                    try {
                        const badge = document.getElementById('headlessBadge');
                        const isHeadless = badge && badge.textContent && badge.textContent.indexOf('Headless') >= 0;
                        await postJson('/api/instances/headless', { isHeadless: !isHeadless });
                        headlessConfirmModal.hide();
                        showToast('已切换', 'Headless 模式已切换，正在重建实例并刷新插件。', false);
                        await refreshStatus();
                    } catch (e) {
                        showToast('失败', e.message || '切换 Headless 失败', true);
                    } finally {
                        headlessConfirmProgress.classList.add('d-none');
                        newSubmit.disabled = false;
                    }
                });
            }
            conn.onclose(()        => {
                browserHubConnectionId = null;
                if (window.BrowserIndex) window.BrowserIndex.browserHubConnectionId = null;
                status.textContent = "已断开"; status.className = "badge bg-danger";
                noSig.style.display = "flex";
            });

            conn.start()
                .then(async () => {
                    browserHubConnectionId = conn.connectionId || null;
                    status.textContent = "已连接";
                    status.className = "badge bg-success";
                    await refreshStatus();
                    await loadPlugins();
                    scheduleScreencastSync(true);
                })
                .catch(e  => { status.textContent = "连接失败"; status.className = "badge bg-danger"; console.error(e); });

            // toast helper
            function showToast(title, message, isError) {
                const container = document.getElementById('toastContainer');
                if (!container) return;
                const toastEl = document.createElement('div');
                toastEl.className = 'toast align-items-center text-bg-' + (isError ? 'danger' : 'success') + ' border-0';
                toastEl.setAttribute('role', 'status');
                toastEl.setAttribute('aria-live', 'polite');
                toastEl.setAttribute('aria-atomic', 'true');
                toastEl.innerHTML = `<div class="d-flex"><div class="toast-body"><strong>${title}</strong><div>${message}</div></div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button></div>`;
                container.appendChild(toastEl);
                const toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
            }

            function showOperationModal(title, message, errors) {
                const modal = document.getElementById('pluginOperationModal');
                const modalTitle = document.getElementById('pluginOperationModalTitle');
                const modalMessage = document.getElementById('pluginOperationModalMessage');
                const modalErrors = document.getElementById('pluginOperationModalErrors');
                if (!modal || !modalTitle || !modalMessage || !modalErrors) return;
                modalTitle.textContent = title || '操作结果';
                modalMessage.textContent = message || '';
                modalErrors.innerHTML = '';
                if (errors && errors.length) {
                    const ul = document.createElement('ul');
                    for (const e of errors) {
                        const li = document.createElement('li');
                        li.textContent = e;
                        ul.appendChild(li);
                    }
                    modalErrors.appendChild(ul);
                }
                const bsModal = new bootstrap.Modal(modal);
                bsModal.show();
            }

            async function postJson(url, body) {
                const headers = { "Content-Type": "application/json" };
                if (browserHubConnectionId)
                    headers["X-BrowserHub-ConnectionId"] = browserHubConnectionId;

                const response = await fetch(url, {
                    method: "POST",
                    headers,
                    body: JSON.stringify(body ?? {})
                });

                if (!response.ok) {
                    let message = "请求失败: " + response.status;
                    const contentType = response.headers.get("content-type") || "";
                    if (contentType.includes("application/json")) {
                        const payload = await response.json().catch(() => null);

                        // 支持 ProblemDetails（RFC7807）和自定义 { message } 结构
                        if (payload) {
                            message = payload.detail || payload.message || payload.title || message;
                        }
                    } else {
                        const text = await response.text().catch(() => "");
                        if (text)
                            message = text;
                    }

                    const err = new Error(message);
                    err.status = response.status;
                    err.url = url;
                    throw err;
                }

                return await response.json();
            }

            // When the create-instance modal is shown, fetch a preview path and fill placeholder.
            (function() {
                const createModalEl = document.getElementById('createInstanceModal');
                if (!createModalEl) return;

                createModalEl.addEventListener('shown.bs.modal', async () => {
                    try {
                        const owner = document.getElementById('createInstanceOwnerPluginId')?.value || 'ui';
                        const resp = await (await fetch('/api/instances/preview?ownerPluginId=' + encodeURIComponent(owner))).json();
                        let previewPath = resp?.userDataDirectory || '';
                        const originalPreviewPath = previewPath;
                        const previewId = resp?.instanceId || '';

                        const input = document.getElementById('createInstanceUserDataDirectory');
                        const previewDiv = document.getElementById('createInstancePreview');
                        const previewNameEl = document.getElementById('createInstancePreviewName');
                        const previewPathEl = document.getElementById('createInstancePreviewPath');
                        const displayNameInput = document.getElementById('createInstanceDisplayName');

                        if (input) {
                            input.placeholder = previewPath;
                            input.dataset.previewPath = previewPath;
                            input.dataset.previewId = previewId;
                            input.classList.add('placeholder-italic');

                            // hover tooltip for full path with copy button
                            const tip = document.getElementById('createInstancePathTooltip');
                            if (tip) {
                                const tipText = tip.querySelector('.create-path-text');
                                const copyBtn = tip.querySelector('.create-path-copy-btn');

                                function showTip(always) {
                                    // show when userData input is empty, or when caller forces (e.g. display name focused)
                                    if (always || !input.value) {
                                        if (tipText) tipText.textContent = previewPath || '';
                                        tip.style.display = previewPath ? '' : 'none';
                                        // ensure tooltip is positioned under the input and visible
                                        try {
                                            const rect = input.getBoundingClientRect();
                                            tip.style.position = 'relative';
                                            tip.style.marginTop = '0.5rem';
                                            tip.style.left = '0';
                                        } catch (e) { }
                                    }
                                }

                                // show tooltip when the input is focused or clicked
                                input.addEventListener('focus', () => showTip(false));
                                input.addEventListener('click', () => showTip(false));
                                input.addEventListener('blur', () => { if (tip) tip.style.display = 'none'; });

                                // do not show tooltip when display name is focused

                                if (copyBtn) {
                                    // prevent mousedown from blurring the input so click can be handled
                                    copyBtn.addEventListener('mousedown', (e) => { e.preventDefault(); e.stopPropagation(); });
                                    copyBtn.addEventListener('click', async (e) => {
                                        try {
                                            const text = (previewPath || '') || (input.value || '');
                                            await navigator.clipboard.writeText(text);
                                            showError('已复制到剪贴板', 'info');
                                        } catch (ex) {
                                            showError('复制失败: ' + (ex?.message || ex), 'warning');
                                        }
                                    });
                                }
                            }

                            // validation: ensure folder name can be created when user relies on display name
                            async function validateFolderName(rootPath, folderName) {
                                try {
                                    const payload = { rootPath: rootPath, folderName: folderName };
                                    const res = await postJson('/api/instances/validate-folder', payload);
                                    return res;
                                } catch (e) {
                                    return { valid: false, message: e.message };
                                }
                            }

                            const displayNameInput = document.getElementById('createInstanceDisplayName');
                            const submitBtn = document.getElementById('createInstanceSubmitBtn');
                            // when display name changes, if userData left empty, validate folder name
                            if (displayNameInput) {
                                displayNameInput.addEventListener('input', () => {
                                    // optimistic: enable submit until validation completes
                                    if (submitBtn) submitBtn.disabled = false;
                                });

                                displayNameInput.addEventListener('blur', async () => {
                                    const val = (displayNameInput.value || '').trim();
                                    const userPath = (input.value || '').trim();
                                    if (!val) return;
                                    if (userPath) return; // user provided explicit path; skip

                                    const root = previewPath ? previewPath.replace(/\\[^\\]+$/, '') : '';
                                    if (!root) return;

                                    const r = await validateFolderName(root, val);
                                    if (!r || !r.valid) {
                                        if (submitBtn) submitBtn.disabled = true;
                                        showError(r?.message || '实例名不可用');
                                    } else {
                                        if (submitBtn) submitBtn.disabled = false;
                                        // update preview name and path display
                                        const previewNameEl = document.getElementById('createInstancePreviewName');
                                        const previewPathEl = document.getElementById('createInstancePreviewPath');
                                        if (previewNameEl) previewNameEl.querySelector('span').textContent = val;
                                        if (previewPathEl) previewPathEl.querySelector('span').textContent = r.fullPath || (root + '/' + val);
                                        // store previewId as the folder name so creation uses it
                                        input.dataset.previewId = val;
                                    }
                                });
                            }

                            // when user manually types a path, validate it as full path
                            input.addEventListener('blur', async () => {
                                const val = (input.value || '').trim();
                                if (!val) return;
                                // if val is a full path, try validating the folder portion
                                let root = val.replace(/\\[^\\]+$/, '');
                                let folder = val.split('\\').pop();
                                const r = await validateFolderName(root, folder);
                                if (!r || !r.valid) {
                                    if (submitBtn) submitBtn.disabled = true;
                                    showError(r?.message || '指定的 UserData 目录不可创建');
                                } else {
                                    if (submitBtn) submitBtn.disabled = false;
                                }
                            });
                        }

                        // move preview values into input placeholders
                        if (displayNameInput) {
                            // set placeholder to the preview id only (or keep default hint when absent)
                            displayNameInput.placeholder = previewId || '留空使用默认名';
                            displayNameInput.dataset.previewId = previewId || '';
                            // when display name changes, update path placeholder and tooltip accordingly
                            displayNameInput.addEventListener('input', () => {
                                const val = (displayNameInput.value || '').trim();
                                if (val) {
                                    // user provided a custom display name: update path preview
                                    const root = originalPreviewPath ? originalPreviewPath.replace(/\\[^\\]+$/, '') : '';
                                    const newPath = root ? (root + '\\' + val) : originalPreviewPath;
                                    previewPath = newPath;
                                    if (input) {
                                        input.placeholder = newPath;
                                        input.dataset.previewPath = newPath;
                                    }
                                    // update tooltip text immediately if visible
                                    const tip = document.getElementById('createInstancePathTooltip');
                                    if (tip) {
                                        const tipText = tip.querySelector('.create-path-text');
                                        if (tipText) tipText.textContent = newPath || '';
                                    }
                                } else {
                                    // restore original previewPath
                                    previewPath = originalPreviewPath;
                                    if (input) {
                                        input.placeholder = originalPreviewPath;
                                        input.dataset.previewPath = originalPreviewPath;
                                    }
                                    const tip = document.getElementById('createInstancePathTooltip');
                                    if (tip) {
                                        const tipText = tip.querySelector('.create-path-text');
                                        if (tipText) tipText.textContent = originalPreviewPath || '';
                                    }
                                }
                            });
                        }
                        if (input) {
                            // ensure path placeholder already set earlier; also store previewId
                            input.dataset.previewId = input.dataset.previewId || previewId;
                        }
                    } catch (e) {
                        // ignore preview errors
                    }
                });

                createModalEl.addEventListener('hidden.bs.modal', () => {
                    const previewDiv = document.getElementById('createInstancePreview');
                    if (previewDiv) previewDiv.style.display = 'none';
                });
            })();

            function showError(message, level = 'warning') {
                // Create a Bootstrap toast in the top-right toast container
                try {
                    const container = document.getElementById('toastContainer');
                    if (!container) {
                        // fallback to inline alert
                        browserError.textContent = message || "操作失败，请稍后重试。";
                        browserError.classList.remove("d-none");
                        return;
                    }

                    const id = 'toast-' + Math.random().toString(36).slice(2, 9);
                    const toastEl = document.createElement('div');
                    toastEl.className = 'toast align-items-center text-bg-' + (level === 'error' ? 'danger' : 'warning') + ' border-0';
                    toastEl.role = 'alert';
                    toastEl.ariaLive = 'assertive';
                    toastEl.ariaAtomic = 'true';
                    toastEl.id = id;

                    // allow multi-line content and prefer the server-provided message fully instead of truncating to status
                    toastEl.innerHTML = `
                        <div class="d-flex">
                            <div class="toast-body small" style="max-width:400px;white-space:pre-wrap">${(message || '').replace(/</g,'&lt;')}</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>`;

                    // Avoid showing duplicate toasts with identical text repeatedly
                    const key = (message || '').trim();
                    if (shownMessages.has(key)) {
                        // Already shown this message once; do not show again
                        return;
                    }
                    shownMessages.add(key);

                    container.appendChild(toastEl);
                    const toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                    toast.show();
                    // remove from DOM after hidden and allow message to be shown again in future
                    toastEl.addEventListener('hidden.bs.toast', () => {
                        toastEl.remove();
                        try { shownMessages.delete(key); } catch { }
                    });
                } catch (ex) {
                    // fallback
                    browserError.textContent = message || "操作失败，请稍后重试。";
                    browserError.classList.remove("d-none");
                }
            }

            function clearError() {
                browserError.textContent = "";
                browserError.classList.add("d-none");
            }

            function normalizePath(path) {
                return (path || "").trim().replace(/[\\/]+$/, "").toLowerCase();
            }

            function roundViewportWidth(value) {
                return Math.max(320, Math.round(Number(value) || 0));
            }

            function roundViewportHeight(value) {
                return Math.max(240, Math.round(Number(value) || 0));
            }

            function refreshInstanceSettingsAspectRatio() {
                const width = Number(instanceViewportWidthInput.value);
                const height = Number(instanceViewportHeightInput.value);
                instanceSettingsAspectRatio = width > 0 && height > 0 ? width / height : null;
            }

            function syncInstanceHeightFromWidth() {
                if (synchronizingAspectRatio || !instancePreserveAspectRatioInput.checked || !instanceSettingsAspectRatio)
                    return;

                const width = Number(instanceViewportWidthInput.value);
                if (!(width > 0))
                    return;

                synchronizingAspectRatio = true;
                instanceViewportHeightInput.value = String(roundViewportHeight(width / instanceSettingsAspectRatio));
                synchronizingAspectRatio = false;
            }

            function syncInstanceWidthFromHeight() {
                if (synchronizingAspectRatio || !instancePreserveAspectRatioInput.checked || !instanceSettingsAspectRatio)
                    return;

                const height = Number(instanceViewportHeightInput.value);
                if (!(height > 0))
                    return;

                synchronizingAspectRatio = true;
                instanceViewportWidthInput.value = String(roundViewportWidth(height * instanceSettingsAspectRatio));
                synchronizingAspectRatio = false;
            }

            async function syncCurrentInstanceViewport(force = false) {
                if (!currentInstanceViewport?.autoResizeViewport || !selectedInstanceId)
                    return;

                const viewport = getCanvasViewportSize();
                if (applyingInstanceViewportSync) {
                    pendingInstanceViewportSync = true;
                    return;
                }

                applyingInstanceViewportSync = true;
                try {
                    await postJson("/api/instances/viewport", {
                        width: viewport.width,
                        height: viewport.height
                    });
                } catch (e) {
                    if (force)
                        showError(e.message || "实例网页尺寸同步失败。");
                } finally {
                    applyingInstanceViewportSync = false;
                    const needsAnotherSync = pendingInstanceViewportSync;
                    pendingInstanceViewportSync = false;
                    if (needsAnotherSync)
                        scheduleCurrentInstanceViewportSync(force);
                }
            }

            function scheduleCurrentInstanceViewportSync(force = false) {
                if (!currentInstanceViewport?.autoResizeViewport)
                    return;

                if (instanceViewportSyncTimer)
                    clearTimeout(instanceViewportSyncTimer);

                instanceViewportSyncTimer = setTimeout(() => {
                    syncCurrentInstanceViewport(force).catch(() => { });
                }, force ? 0 : 150);
            }

            function syncInstanceUserAgentEditorState() {
                const locked = instanceUseProgramUserAgentInput.disabled;
                const useProgramUserAgent = locked || instanceUseProgramUserAgentInput.checked;
                instanceUserAgentInput.disabled = useProgramUserAgent;
                instanceUserAgentLockHint.classList.toggle("d-none", !locked);
            }

            function applyInstanceUserAgentSettings(userAgent) {
                const locked = !!userAgent?.isLocked;
                instanceUseProgramUserAgentInput.checked = locked || !!userAgent?.useProgramUserAgent;
                instanceUseProgramUserAgentInput.disabled = locked;
                instanceUserAgentInput.value = userAgent?.userAgent || "";
                instanceUserAgentProgramHint.textContent = userAgent?.programUserAgent
                    ? "程序设置 UA：" + userAgent.programUserAgent
                    : "程序设置 UA：未设置";
                instanceUserAgentEffectiveHint.textContent = userAgent?.effectiveUserAgent
                    ? "当前生效 UA：" + userAgent.effectiveUserAgent
                    : "当前生效 UA：浏览器默认";
                syncInstanceUserAgentEditorState();
            }

            function applyInstanceSettingsForm(data, fallbackName) {
                instanceSettingsModalTitle.textContent = (data.instanceName || fallbackName || "实例") + " 设置";
                instanceSettingsModalSummary.textContent = "实例 ID: " + (data.instanceId || "") + (data.isSelected ? " · 当前实例" : "");
                instanceSettingsInstanceIdInput.value = data.instanceId || "";
                instanceSettingsCurrentUserDataDirectoryInput.value = data.userDataDirectory || "";
                instanceSettingsIsSelectedInput.value = data.isSelected ? "true" : "false";
                instanceUserDataDirectoryInput.value = data.userDataDirectory || "";
                applyInstanceUserAgentSettings(data.userAgent);
                instanceViewportWidthInput.value = String(data.viewport?.width || 1280);
                instanceViewportHeightInput.value = String(data.viewport?.height || 800);
                instancePreserveAspectRatioInput.checked = !!data.viewport?.preserveAspectRatio;
                instanceAutoResizeViewportInput.checked = !!data.viewport?.autoResizeViewport;
                refreshInstanceSettingsAspectRatio();
                instanceSettingsSubmitBtn.disabled = false;
            }

            async function openInstanceSettings(instanceId, fallbackName) {
                if (!instanceSettingsModal)
                    return;

                clearError();
                try {
                    const response = await fetch("/api/instances/settings?instanceId=" + encodeURIComponent(instanceId));
                    if (!response.ok)
                        throw new Error("实例设置获取失败: " + response.status);

                    applyInstanceSettingsForm(await response.json(), fallbackName);
                    instanceSettingsModal.show();
                } catch (e) {
                    showError(e.message || "实例设置获取失败。");
                }
            }

            function showCanvasOverlay(message, fillBlack = false) {
                if (!liveDisplayEnabled) {
                    noSig.style.display = "none";
                    return;
                }

                if (fillBlack) {
                    const viewport = getCanvasViewportSize();
                    resizeCanvasBuffer(viewport.width, viewport.height);
                    ctx.fillStyle = "#000";
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                }

                noSig.textContent = message;
                noSig.style.display = "flex";
            }

            function hideTemporaryCanvasOverlay() {
                if (noSig.textContent === "Resetting Canvas")
                    noSig.style.display = "none";
            }

            function updateTabsShellVisibility() {
                tabsShell?.classList.toggle("d-none", !liveDisplayEnabled);
            }

            function setLiveDisplayEnabled(enabled) {
                liveDisplayEnabled = enabled;
                liveToggleBtn.textContent = enabled ? "实时画面" : "TAB 状态";
                liveToggleBtn.className = "btn btn-sm browser-live-toggle " + (enabled ? "btn-primary" : "btn-danger");
                liveToggleBtn.setAttribute("aria-pressed", enabled ? "true" : "false");
                canvas.classList.toggle("d-none", !enabled);
                tabsStatusPanel.classList.toggle("d-none", enabled);
                updateTabsShellVisibility();
                if (!enabled)
                    noSig.style.display = "none";
            }

            function setScreencastAvailability(available) {
                screencastAvailable = available;
                liveToggleBtn.disabled = !available;

                if (!available) {
                    liveDisplayEnabled = false;
                    liveToggleBtn.textContent = "已显示窗口";
                    liveToggleBtn.className = "btn btn-sm browser-live-toggle btn-secondary";
                    liveToggleBtn.setAttribute("aria-pressed", "false");
                    canvas.classList.add("d-none");
                    tabsStatusPanel.classList.remove("d-none");
                    noSig.style.display = "none";
                }

                updateTabsShellVisibility();
            }

            function applyStatus(data) {
                const previousInstanceId = selectedInstanceId;
                const previousViewportSignature = JSON.stringify(currentInstanceViewport || null);
                selectedInstanceId = data.currentInstanceId || null;
                currentInstanceViewport = data.currentInstanceViewport || null;

                document.title = (data.title || "浏览器控制台") + " - MeowAutoChrome";
                if (!isEditingUrl)
                    urlInput.value = data.url || "";
                if (data.errorMessage)
                    showError(data.errorMessage);
                else
                    clearError();

                // 当没有实例时，显示右上角红色胶囊并禁止截图按钮
                const hasInstance = !!selectedInstanceId;
                if (!hasInstance) {
                    if (instanceStatusBadge) {
                        instanceStatusBadge.classList.remove("d-none");
                        instanceStatusBadge.className = "badge bg-danger ms-2";
                        instanceStatusBadge.textContent = "无实例";
                    }
                } else {
                    if (instanceStatusBadge)
                        instanceStatusBadge.classList.add("d-none");
                }

                // 更新 Headless 徽章（兼容 camelCase 与 PascalCase）
                try {
                    const hb = document.getElementById('headlessBadge');
                    if (hb) {
                        const isHeadless = (data?.isHeadless === true) || (data?.IsHeadless === true);
                        hb.textContent = isHeadless ? 'Headless' : 'Headful';
                        hb.className = 'badge ' + (isHeadless ? 'bg-secondary' : 'bg-success');
                    }
                } catch (e) { }

                setScreencastAvailability(data.supportsScreencast !== false && hasInstance);
                if (screencastAvailable)
                    setLiveDisplayEnabled(data.screencastEnabled);

                // 禁用截图按钮，若不支持录屏或无实例
                if (shotBtn)
                    shotBtn.disabled = !(data.supportsScreencast && hasInstance);
                targetFrameIntervalMs = data.screencastFrameIntervalMs;
                resizeCanvasBuffer(data.screencastMaxWidth, data.screencastMaxHeight);
                renderFpsDisplay();
                renderResourceMetrics(data);
                renderTabs(data.tabs || []);
                renderTabsStatus(data.tabs || []);

                if (!pointerResizeActive && data.pluginPanelWidth)
                    applyPluginPanelWidth(data.pluginPanelWidth);

                if (currentInstanceViewport?.autoResizeViewport) {
                    const nextViewportSignature = JSON.stringify(currentInstanceViewport || null);
                    if (previousInstanceId !== selectedInstanceId || previousViewportSignature !== nextViewportSignature)
                        scheduleCurrentInstanceViewportSync();
                }

                if (!data.screencastEnabled) {
                    noSig.style.display = "none";
                } else {
                    hideTemporaryCanvasOverlay();
                }
            }

            function formatPluginOutputTime(timestampUtc) {
                if (!timestampUtc)
                    return "";

                const date = new Date(timestampUtc);
                return Number.isNaN(date.getTime()) ? "" : date.toLocaleString();
            }

            function getPluginTarget(plugin, targetId) {
                if (!plugin || !targetId)
                    return null;

                return (plugin.controls || []).find(control => control.command === targetId)
                    || (plugin.functions || []).find(fn => fn.id === targetId)
                    || null;
            }

            function summarizePluginOutput(message, data) {
                if (message)
                    return message;

                const firstEntry = Object.entries(data || {})[0];
                return firstEntry ? (firstEntry[0] + ": " + (firstEntry[1] || "")) : "暂无返回值";
            }

            function renderPluginOutputRows(container, data, emptyText) {
                container.replaceChildren();

                const entries = Object.entries(data || {});
                // filter out internal 'state' key so it is not shown as a separate row
                const filtered = entries.filter(([k]) => String(k || "").toLowerCase() !== "state");
                if (!filtered.length) {
                    const empty = document.createElement("div");
                    empty.className = "plugin-output-empty";
                    empty.textContent = emptyText;
                    container.appendChild(empty);
                    return;
                }

                for (const [key, value] of filtered) {
                    const row = document.createElement("div");
                    row.className = "plugin-output-row";

                    const label = document.createElement("div");
                    label.className = "plugin-output-label";
                    label.textContent = key;

                    const content = document.createElement("div");
                    content.className = "plugin-output-value";
                    content.textContent = value || "";

                    row.appendChild(label);
                    row.appendChild(content);
                    container.appendChild(row);
                }
            }

            function syncPluginOutputUi(pluginId) {
                const ui = pluginOutputUi.get(pluginId);
                if (!ui)
                    return;

                const output = pluginOutputStore.get(pluginId);
                ui.button.disabled = !output;

                if (!output) {
                    ui.badge.classList.add("d-none");
                    return;
                }

                // show unread count (fallback to total entries if unreadCount not present)
                const unread = Math.min(Number(output.unreadCount ?? (output.entries || []).length) || 0, 99);
                ui.badge.textContent = unread > 0 ? String(unread) : "";
                ui.badge.classList.toggle("d-none", unread === 0);

                // no per-target UI update here; per-target statuses are shown inside the plugin output modal
            }

            function renderPluginOutputModal(pluginId) {
                const output = pluginOutputStore.get(pluginId);
                if (!output)
                    return;

                const plugin = pluginCatalog.get(pluginId);
                const target = getPluginTarget(plugin, output.targetId);
                pluginOutputModalTitle.textContent = plugin?.name
                    ? plugin.name + (target?.name ? " · " + target.name : "")
                    : "插件输出";

                pluginOutputModalSummary.textContent = [formatPluginOutputTime(output.updatedAt), summarizePluginOutput(output.message, output.data)]
                    .filter(Boolean)
                    .join(" · ");
                pluginOutputModalSummary.classList.toggle("d-none", !pluginOutputModalSummary.textContent);

                renderPluginOutputRows(pluginOutputModalData, output.data, "当前还没有结构化返回值。");
                // render current target status to the left of the "当前返回值" heading
                try {
                    const outputContainer = pluginOutputModalData?.parentElement;
                    if (outputContainer) {
                        const currentLabel = outputContainer.querySelector(".fw-semibold");
                        // remove existing status if present
                        const existing = outputContainer.querySelector(".plugin-output-current-status");
                        if (existing) existing.remove();

                        if (currentLabel) {
                            // make the label inline and centered
                            currentLabel.style.display = "inline-flex";
                            currentLabel.style.alignItems = "center";

                            const state = (output.targetStates && output.targetStates[output.targetId]) || plugin?.state || "";
                            const ds = getPluginStateDisplayByName(state);
                            const statusBtn = document.createElement("button");
                            statusBtn.type = "button";
                            // place status to the left of the label
                            statusBtn.className = (ds.className || "btn btn-sm btn-outline-secondary") + " plugin-output-current-status me-2";
                            statusBtn.disabled = true;
                            statusBtn.style.pointerEvents = "none";
                            statusBtn.textContent = ds.text || "";

                            currentLabel.parentElement.insertBefore(statusBtn, currentLabel);
                        }
                    }
                } catch (e) {
                    // ignore modal UI errors
                }

                pluginOutputModalEntries.replaceChildren();

                if (!(output.entries || []).length) {
                    const empty = document.createElement("div");
                    empty.className = "plugin-output-empty";
                    empty.textContent = "还没有输出记录。";
                    pluginOutputModalEntries.appendChild(empty);
                    return;
                }

                for (const entry of output.entries) {
                    const item = document.createElement("div");
                    item.className = "plugin-output-entry";

                    const header = document.createElement("div");
                    header.className = "d-flex justify-content-between align-items-start gap-2 mb-2";

                    const name = document.createElement("div");
                    name.className = "fw-semibold small";
                    name.textContent = getPluginTarget(plugin, entry.targetId)?.name || entry.targetId || "插件输出";

                    const time = document.createElement("div");
                    time.className = "text-muted small";
                    time.textContent = formatPluginOutputTime(entry.timestampUtc);

                    // insert a small disabled status button to the left of the entry name
                    try {
                        const state = (output.targetStates && output.targetStates[entry.targetId]) || plugin?.state || "";
                        const ds = getPluginStateDisplayByName(state);
                        const entryStatus = document.createElement("button");
                        entryStatus.type = "button";
                        entryStatus.className = (ds.className || "btn btn-sm btn-outline-secondary") + " me-2";
                        entryStatus.disabled = true;
                        entryStatus.style.pointerEvents = "none";
                        entryStatus.textContent = ds.text || "";
                        header.insertBefore(entryStatus, name);
                    } catch (e) {
                        // ignore
                    }
                    header.appendChild(name);
                    header.appendChild(time);
                    item.appendChild(header);

                    if (entry.message) {
                        const message = document.createElement("div");
                        message.className = "plugin-output-value mb-2";
                        message.textContent = entry.message;
                        item.appendChild(message);
                    }

                    const dataContainer = document.createElement("div");
                    renderPluginOutputRows(dataContainer, entry.data, "本次输出没有附加字段。");
                    item.appendChild(dataContainer);
                    pluginOutputModalEntries.appendChild(item);
                }
            }

            function openPluginOutputModal(pluginId) {
                const output = pluginOutputStore.get(pluginId);
                if (!output || !pluginOutputModal)
                    return;

                activePluginOutputPluginId = pluginId;
                // mark as read when opening
                try {
                    const updated = { ...(output || {}) };
                    updated.unreadCount = 0;
                    pluginOutputStore.set(pluginId, updated);
                } catch (e) { }

                renderPluginOutputModal(pluginId);
                // refresh the badge UI
                syncPluginOutputUi(pluginId);
                pluginOutputModal.show();
            }

            function applyPluginOutputUpdate(update) {
                if (!update?.pluginId)
                    return;
                const existing = pluginOutputStore.get(update.pluginId);
                const mergedData = { ...(existing?.data || {}), ...(update.data || {}) };
                const isCurrentModal = activePluginOutputPluginId === update.pluginId && pluginOutputModalElement.classList.contains("show");

                const next = {
                    pluginId: update.pluginId,
                    targetId: update.targetId || existing?.targetId || "",
                    message: update.message ?? existing?.message ?? "",
                    data: mergedData,
                    updatedAt: update.timestampUtc || new Date().toISOString(),
                    entries: existing?.entries ? [...existing.entries] : [],
                    // carry existing target-specific states and apply incoming state if any
                    targetStates: existing?.targetStates ? { ...existing.targetStates } : {},
                    // unread count: carry existing value
                    unreadCount: Number(existing?.unreadCount || 0)
                };

                if (update.message || Object.keys(update.data || {}).length) {
                    next.entries.unshift({
                        targetId: next.targetId,
                        message: update.message || "",
                        data: update.data || {},
                        timestampUtc: next.updatedAt
                    });
                    next.entries = next.entries.slice(0, 30);

                    // increment unread count if modal not currently open for this plugin
                    if (!isCurrentModal)
                        next.unreadCount = (Number(existing?.unreadCount || 0) || 0) + 1;
                    else
                        next.unreadCount = 0;
                }

                if (update.state) {
                    next.targetStates[next.targetId] = update.state;
                }

                pluginOutputStore.set(update.pluginId, next);
                syncPluginOutputUi(update.pluginId);

                if (isCurrentModal)
                    renderPluginOutputModal(update.pluginId);
            }

            function createPluginParameterField(parameter, parameterInputs) {
                const field = document.createElement("div");

                const label = document.createElement("label");
                label.className = "form-label mb-1";
                label.textContent = parameter.label + (parameter.required ? " *" : "");
                field.appendChild(label);

                let input;
                if (parameter.inputType === "checkbox") {
                    input = document.createElement("input");
                    input.type = "checkbox";
                    input.className = "form-check-input";
                    input.checked = String(parameter.defaultValue || "false").toLowerCase() === "true";

                    const wrapper = document.createElement("div");
                    wrapper.className = "form-check";
                    wrapper.appendChild(input);
                    field.appendChild(wrapper);
                } else if (parameter.inputType === "select") {
                    input = document.createElement("select");
                    input.className = "form-select form-select-sm";

                    if (!parameter.required) {
                        const emptyOption = document.createElement("option");
                        emptyOption.value = "";
                        emptyOption.textContent = "请选择";
                        input.appendChild(emptyOption);
                    }

                    for (const option of parameter.options || []) {
                        const element = document.createElement("option");
                        element.value = option.value;
                        element.textContent = option.label;
                        if ((parameter.defaultValue ?? "") === option.value)
                            element.selected = true;
                        input.appendChild(element);
                    }

                    field.appendChild(input);
                } else {
                    input = document.createElement("input");
                    input.type = parameter.inputType === "number"
                        ? "number"
                        : parameter.inputType === "datetime-local"
                            ? "datetime-local"
                            : "text";
                    input.className = "form-control form-control-sm";
                    input.value = parameter.defaultValue ?? "";
                    input.placeholder = parameter.description || parameter.label;
                    if (parameter.inputType === "number")
                        input.step = "any";
                    if (parameter.inputType === "datetime-local")
                        input.step = "1";
                    if (parameter.inputType === "guid") {
                        input.placeholder = parameter.description || "00000000-0000-0000-0000-000000000000";
                        input.pattern = "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$";
                        input.spellcheck = false;
                        input.autocomplete = "off";
                    }
                    field.appendChild(input);
                }

                if (parameter.description) {
                    const help = document.createElement("div");
                    help.className = "form-text mt-1";
                    help.textContent = parameter.description;
                    field.appendChild(help);
                }

                parameterInputs[parameter.name] = { input, parameter };
                return field;
            }

            function collectPluginArguments(parameterInputs) {
                const argumentsPayload = {};
                for (const [name, entry] of Object.entries(parameterInputs || {})) {
                    if (typeof entry.input.checkValidity === "function" && !entry.input.checkValidity()) {
                        entry.input.reportValidity();
                        entry.input.focus();
                        return null;
                    }

                    if (entry.parameter.inputType === "checkbox") {
                        argumentsPayload[name] = entry.input.checked ? "true" : "false";
                        continue;
                    }

                    const value = (entry.input.value || "").trim();
                    if (entry.parameter.required && !value) {
                        showError("请填写参数：" + entry.parameter.label);
                        entry.input.focus();
                        return null;
                    }

                    if (value)
                        argumentsPayload[name] = value;
                }

                return argumentsPayload;
            }

            function openPluginArgumentModal(title, description, parameters, submitText, onSubmit) {
                if (!pluginArgumentModal)
                    return;

                const parameterInputs = {};
                pluginArgumentModalTitle.textContent = title || "插件参数";
                pluginArgumentModalDescription.textContent = description || "";
                pluginArgumentModalDescription.classList.toggle("d-none", !description);
                pluginArgumentForm.replaceChildren();

                for (const parameter of parameters || [])
                    pluginArgumentForm.appendChild(createPluginParameterField(parameter, parameterInputs));

                pluginArgumentSubmitBtn.textContent = submitText || "执行";
                pendingPluginInvocation = { parameterInputs, onSubmit };
                clearError();
                pluginArgumentModal.show();

                window.setTimeout(() => {
                    const firstInput = pluginArgumentForm.querySelector("input, select, textarea");
                    if (firstInput)
                        firstInput.focus();
                }, 150);
            }

            async function invokePluginTarget(plugin, target, kind, triggerButton) {
                const execute = async argumentsPayload => {
                    const result = kind === "control"
                        ? await postJson('pluginsControl', {
                            pluginId: plugin.id,
                            command: target.command,
                            arguments: argumentsPayload
                        })
                        : await postJson('pluginsRun', {
                            pluginId: plugin.id,
                            functionId: target.id,
                            arguments: argumentsPayload
                        });

                    applyPluginOutputUpdate({
                        pluginId: result.pluginId || plugin.id,
                        targetId: result.targetId || (kind === "control" ? target.command : target.id),
                        message: result.message,
                        state: result.state,
                        data: result.data || {},
                        openModal: true,
                        timestampUtc: new Date().toISOString()
                    });
                    await loadPlugins();
                    await refreshStatus();
                    await loadPlugins();
                    await refreshStatus();
                };

                if ((target.parameters || []).length) {
                    openPluginArgumentModal(
                        plugin.name + " - " + target.name,
                        target.description,
                        target.parameters,
                        kind === "control" ? target.name : "执行",
                        execute);
                    return;
                }

                triggerButton.disabled = true;
                clearError();
                try {
                    await execute({});
                } catch (e) {
                    showError(e.message || (kind === "control" ? "插件控制失败。" : "插件函数执行失败。"));
                } finally {
                    triggerButton.disabled = false;
                }
            }

            pluginArgumentSubmitBtn.addEventListener("click", async () => {
                if (!pendingPluginInvocation)
                    return;

                const argumentsPayload = collectPluginArguments(pendingPluginInvocation.parameterInputs);
                if (argumentsPayload === null)
                    return;

                pluginArgumentSubmitBtn.disabled = true;
                clearError();
                try {
                    await pendingPluginInvocation.onSubmit(argumentsPayload);
                    pluginArgumentModal.hide();
                } catch (e) {
                    showError(e.message || "插件执行失败。");
                } finally {
                    pluginArgumentSubmitBtn.disabled = false;
                }
            });

            pluginArgumentModalElement.addEventListener("hidden.bs.modal", () => {
                pendingPluginInvocation = null;
                pluginArgumentForm.replaceChildren();
                pluginArgumentModalDescription.textContent = "";
                pluginArgumentModalDescription.classList.add("d-none");
                pluginArgumentSubmitBtn.textContent = "执行";
                pluginArgumentSubmitBtn.disabled = false;
            });

            screenshotPreviewModalElement.addEventListener("hidden.bs.modal", () => {
                screenshotPreviewImage.removeAttribute("src");
                if (!screenshotPreviewUrl)
                    return;

                URL.revokeObjectURL(screenshotPreviewUrl);
                screenshotPreviewUrl = null;
            });

            pluginOutputModalElement.addEventListener("hidden.bs.modal", () => {
                activePluginOutputPluginId = null;
                pluginOutputModalTitle.textContent = "插件输出";
                pluginOutputModalSummary.textContent = "";
                pluginOutputModalSummary.classList.add("d-none");
                pluginOutputModalData.replaceChildren();
                pluginOutputModalEntries.replaceChildren();
            });

            instanceSettingsModalElement.addEventListener("hidden.bs.modal", () => {
                instanceSettingsInstanceIdInput.value = "";
                instanceSettingsCurrentUserDataDirectoryInput.value = "";
                instanceSettingsIsSelectedInput.value = "false";
                instanceUserDataDirectoryInput.value = "";
                instanceUseProgramUserAgentInput.checked = true;
                instanceUseProgramUserAgentInput.disabled = false;
                instanceUserAgentInput.value = "";
                instanceUserAgentInput.disabled = true;
                instanceUserAgentProgramHint.textContent = "程序设置 UA：未设置";
                instanceUserAgentEffectiveHint.textContent = "当前生效 UA：浏览器默认";
                instanceUserAgentLockHint.classList.add("d-none");
                instanceViewportWidthInput.value = "1280";
                instanceViewportHeightInput.value = "800";
                instancePreserveAspectRatioInput.checked = false;
                instanceAutoResizeViewportInput.checked = false;
                instanceSettingsAspectRatio = null;
                synchronizingAspectRatio = false;
                instanceSettingsSubmitBtn.disabled = false;
            });

            instanceSettingsSubmitBtn.addEventListener("click", async () => {
                const instanceId = instanceSettingsInstanceIdInput.value.trim();
                const userDataDirectory = instanceUserDataDirectoryInput.value.trim();
                const viewportWidth = roundViewportWidth(instanceViewportWidthInput.value);
                const viewportHeight = roundViewportHeight(instanceViewportHeightInput.value);

                if (!instanceId) {
                    showError("实例 ID 无效。");
                    return;
                }

                if (!userDataDirectory) {
                    showError("请输入 UserData 目录。");
                    instanceUserDataDirectoryInput.focus();
                    return;
                }

                const currentUserDataDirectory = instanceSettingsCurrentUserDataDirectoryInput.value;
                const isSelectedInstance = instanceSettingsIsSelectedInput.value === "true";
                const userDataDirectoryChanged = normalizePath(currentUserDataDirectory) !== normalizePath(userDataDirectory);
                const migrateExistingUserData = userDataDirectoryChanged
                    ? window.confirm("检测到你修改了 UserData 目录。\n\n确定：把旧目录一起迁移过去\n取消：切到新目录但不迁移旧数据")
                    : false;
                const viewport = getCanvasViewportSize();

                instanceSettingsSubmitBtn.disabled = true;
                clearError();
                try {
                    applyStatus(await postJson("/api/instances/settings", {
                        instanceId,
                        userDataDirectory,
                        viewportWidth,
                        viewportHeight,
                        autoResizeViewport: instanceAutoResizeViewportInput.checked,
                        preserveAspectRatio: instancePreserveAspectRatioInput.checked,
                        useProgramUserAgent: instanceUseProgramUserAgentInput.checked || instanceUseProgramUserAgentInput.disabled,
                        userAgent: instanceUseProgramUserAgentInput.checked || instanceUseProgramUserAgentInput.disabled
                            ? null
                            : instanceUserAgentInput.value.trim(),
                        migrateExistingUserData,
                        displayWidth: isSelectedInstance ? viewport.width : null,
                        displayHeight: isSelectedInstance ? viewport.height : null
                    }));
                    instanceSettingsModal.hide();
                } catch (e) {
                    showError(e.message || "实例设置保存失败。");
                } finally {
                    instanceSettingsSubmitBtn.disabled = false;
                }
            });

            function getPluginStateDisplay(plugin) {
                const hasControls = (plugin.controls || []).length > 0;
                const state = hasControls ? (plugin.state || "Unknown") : "NoStartable";

                return state === "Running"
                    ? { text: state, className: "btn btn-sm btn-success" }
                    : state === "Paused"
                        ? { text: state, className: "btn btn-sm btn-warning" }
                        : state === "Stopped"
                            ? { text: state, className: "btn btn-sm btn-secondary" }
                            : state === "NoStartable"
                                ? { text: state, className: "btn btn-sm btn-info" }
                                : { text: state, className: "btn btn-sm btn-outline-secondary" };
            }

            function getPluginStateDisplayByName(state) {
                return state === "Running"
                    ? { text: state, className: "btn btn-sm btn-success" }
                    : state === "Paused"
                        ? { text: state, className: "btn btn-sm btn-warning" }
                        : state === "Stopped"
                            ? { text: state, className: "btn btn-sm btn-secondary" }
                            : state === "NoStartable"
                                ? { text: state, className: "btn btn-sm btn-info" }
                                : { text: state || "", className: "btn btn-sm btn-outline-secondary" };
            }

            function renderPlugins(plugins) {
                pluginHost.replaceChildren();
                pluginCatalog.clear();
                pluginOutputUi.clear();

                // plugin management moved to standalone page (/Home/PluginUpload)

                if (!plugins.length) {
                    const empty = document.createElement("div");
                    empty.textContent = "未发现可用插件。";
                    pluginHost.appendChild(empty);
                    return;
                }

                for (const plugin of plugins) {
                    pluginCatalog.set(plugin.id, plugin);

                    const card = document.createElement("div");
                    card.className = "border rounded p-2";

                    const header = document.createElement("div");
                    header.className = "d-flex justify-content-between align-items-start gap-2 mb-2";

                    const title = document.createElement("div");
                    title.className = "fw-semibold";
                    title.textContent = plugin.name;
                    header.appendChild(title);

                    const headerActions = document.createElement("div");
                    headerActions.className = "d-flex align-items-center gap-2";

                    const stateDisplay = getPluginStateDisplay(plugin);
                    const state = document.createElement("button");
                    state.type = "button";
                    state.className = stateDisplay.className;
                    state.textContent = stateDisplay.text;
                    state.disabled = true;

                    const outputButton = document.createElement("button");
                    outputButton.type = "button";
                    outputButton.className = "btn btn-sm btn-outline-secondary position-relative";
                    outputButton.title = "查看插件输出";
                    outputButton.innerHTML = '<i class="fa-regular fa-envelope me-1"></i>结果';
                    outputButton.disabled = true;
                    outputButton.addEventListener("click", () => openPluginOutputModal(plugin.id));

                    const outputBadge = document.createElement("span");
                    outputBadge.className = "position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none";
                    outputButton.appendChild(outputBadge);
                    headerActions.appendChild(outputButton);
                    headerActions.appendChild(state);

                    // unload button
                    const unloadBtn = document.createElement("button");
                    unloadBtn.type = "button";
                    unloadBtn.className = "btn btn-sm btn-outline-danger";
                    unloadBtn.textContent = "卸载";
                    unloadBtn.title = "卸载此插件（如果可能会卸载整个程序集）";
                    unloadBtn.addEventListener("click", async () => {
                        if (!confirm('确认卸载插件：' + plugin.name + '？')) return;
                        try {
                            unloadBtn.disabled = true;
                    const res = await postJson('plugins', { pluginId: plugin.id });
                            await loadPlugins();
                            if (res?.success) {
                                showToast('卸载成功', plugin.name + ' 已卸载', false);
                            } else {
                                showToast('卸载失败', '请查看详细信息', true);
                                showOperationModal('卸载失败', '卸载插件时发生错误：', [res?.detail || '未知错误']);
                            }
                        } catch (e) {
                            showToast('卸载失败', e.message || String(e), true);
                            showOperationModal('卸载失败', '卸载插件时发生异常：', [e.message || String(e)]);
                        } finally { unloadBtn.disabled = false; }
                    });
                    headerActions.appendChild(unloadBtn);

                    header.appendChild(headerActions);

                    card.appendChild(header);

                    if (plugin.description) {
                        const desc = document.createElement("div");
                        desc.className = "text-muted mb-2";
                        desc.textContent = plugin.description;
                        card.appendChild(desc);
                    }

                    pluginOutputUi.set(plugin.id, {
                        button: outputButton,
                        badge: outputBadge
                    });
                    syncPluginOutputUi(plugin.id);

                    function createCommandButton(text, style, disabled, onClick) {
                        const button = document.createElement("button");
                        button.type = "button";
                        button.className = style;
                        button.textContent = text;
                        button.disabled = disabled;
                        button.addEventListener("click", () => onClick(button));

                        return button;
                    }

                    const visibleControls = plugin.controls || [];
                    if (visibleControls.length) {
                        const controlsCard = document.createElement("div");
                        controlsCard.className = "border rounded p-2 bg-light-subtle mb-3";

                        // controls label removed to keep only buttons

                        const controls = document.createElement("div");
                        controls.className = "d-flex flex-wrap gap-2";

                        for (const control of visibleControls) {
                            const disabled = control.command === "start"
                                ? plugin.state === "Running"
                                : control.command === "stop"
                                    ? plugin.state === "Stopped"
                                    : control.command === "pause"
                                        ? plugin.state !== "Running"
                                        : plugin.state !== "Paused";

                            const button = createCommandButton(control.name, "btn btn-sm btn-outline-secondary", disabled, async triggerButton => {
                                await invokePluginTarget(plugin, control, "control", triggerButton);
                            });
                            button.title = control.description || control.name;
                            controls.appendChild(button);

                            // per-target status will be shown inside the output modal; no status UI here
                        }

                        controlsCard.appendChild(controls);
                        card.appendChild(controlsCard);
                    }

                    const functionCard = document.createElement("div");
                    functionCard.className = "border rounded p-2 bg-light-subtle";

                    // function label removed to keep only buttons

                    if (plugin.functions?.length) {
                        const functionButtons = document.createElement("div");
                        functionButtons.className = "d-flex flex-wrap gap-2";

                        for (const fn of plugin.functions) {
                            const button = createCommandButton(fn.name, "btn btn-sm btn-outline-primary", false, async triggerButton => {
                                await invokePluginTarget(plugin, fn, "function", triggerButton);
                            });
                            button.title = fn.description || fn.name;
                            functionButtons.appendChild(button);

                            // per-target status will be shown inside the output modal; no status UI here
                        }

                        functionCard.appendChild(functionButtons);
                    } else {
                        const empty = document.createElement("div");
                        empty.className = "text-muted";
                        empty.textContent = "无可用函数";
                        functionCard.appendChild(empty);
                    }

                    card.appendChild(functionCard);
                    pluginHost.appendChild(card);
                }
            }

            async function selectTab(tabId) {
                applyStatus(await postJson("/api/tabs/select", { tabId }));
            }

            async function closeInstance(instanceId) {
                applyStatus(await postJson("/api/instances/close", { instanceId }));
            }

            function groupTabsByInstance(tabs) {
                const groups = [];
                const groupMap = new Map();

                for (const tab of tabs) {
                    if (!groupMap.has(tab.instanceId)) {
                        const group = {
                            instanceId: tab.instanceId,
                            instanceName: tab.instanceName || tab.instanceId,
                            instanceColor: tab.instanceColor || "#2563eb",
                            isSelected: !!tab.isInSelectedInstance,
                            tabs: []
                        };

                        groupMap.set(tab.instanceId, group);
                        groups.push(group);
                    }

                    const group = groupMap.get(tab.instanceId);
                    group.isSelected = group.isSelected || !!tab.isInSelectedInstance;
                    group.tabs.push(tab);
                }

                return groups;
            }

            function renderTabs(tabs) {
                tabsBar.innerHTML = "";

                if (!tabs.length) {
                    const empty = document.createElement("div");
                    empty.className = "small text-muted";
                    empty.textContent = "暂无 TAB";
                    tabsBar.appendChild(empty);
                    updateTabScrollButtons();
                    return;
                }

                for (const group of groupTabsByInstance(tabs)) {
                    const groupContainer = document.createElement("div");
                    groupContainer.className = "browser-tab-instance-group" + (group.isSelected ? " browser-tab-instance-group-active" : "");
                    groupContainer.style.setProperty("--instance-color", group.instanceColor);

                    const groupHeader = document.createElement("div");
                    groupHeader.className = "browser-tab-instance-header";

                    const groupLabel = document.createElement("button");
                    groupLabel.type = "button";
                    groupLabel.className = "browser-tab-instance-label" + (group.isSelected ? " browser-tab-instance-label-active" : "");
                    groupLabel.title = "切换到实例：" + group.instanceName;
                    groupLabel.textContent = group.instanceName;
                    groupLabel.addEventListener("click", async () => {
                        const targetTab = group.tabs.find(tab => tab.isSelected) || group.tabs[0];
                        if (!targetTab)
                            return;

                        try {
                            await selectTab(targetTab.id);
                        } catch (e) {
                            showError(e.message || "切换实例失败。");
                        }
                    });
                    groupHeader.appendChild(groupLabel);

                    const groupSettingsBtn = document.createElement("button");
                    groupSettingsBtn.type = "button";
                    groupSettingsBtn.className = "browser-tab-instance-close btn btn-sm btn-light border-0";
                    groupSettingsBtn.title = "实例设置";
                    groupSettingsBtn.setAttribute("aria-label", "实例设置");
                    groupSettingsBtn.innerHTML = '<i class="fa-solid fa-sliders"></i>';
                    groupSettingsBtn.addEventListener("click", async e => {
                        e.stopPropagation();
                        await openInstanceSettings(group.instanceId, group.instanceName);
                    });
                    groupHeader.appendChild(groupSettingsBtn);

                    const groupCloseBtn = document.createElement("button");
                    groupCloseBtn.type = "button";
                    groupCloseBtn.className = "browser-tab-instance-close btn btn-sm btn-light border-0";
                    groupCloseBtn.title = "关闭整个实例";
                    groupCloseBtn.setAttribute("aria-label", "关闭整个实例");
                    groupCloseBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                    groupCloseBtn.addEventListener("click", async e => {
                        e.stopPropagation();
                        try {
                            await closeInstance(group.instanceId);
                        } catch (e) {
                            showError(e.message || "关闭实例失败。");
                        }
                    });
                    groupHeader.appendChild(groupCloseBtn);

                    const groupTabs = document.createElement("div");
                    groupTabs.className = "browser-tab-instance-tabs";

                    for (const tab of group.tabs) {
                        const tabItem = document.createElement("div");
                        tabItem.className = "browser-tab-item" + (tab.isSelected ? " browser-tab-item-active" : "");
                        tabItem.style.setProperty("--instance-color", tab.instanceColor || "#2563eb");

                        const btn = document.createElement("button");
                        btn.type = "button";
                        btn.className = "browser-tab btn btn-sm" + (tab.isSelected ? " browser-tab-active" : "");
                        btn.title = `[${tab.instanceName || tab.instanceId}] ` + (tab.url || tab.title || "about:blank");
                        btn.textContent = tab.title || tab.url || "about:blank";
                        btn.addEventListener("click", async () => {
                            try {
                                await selectTab(tab.id);
                            } catch (e) {
                                showError(e.message || "切换标签页失败。");
                            }
                        });

                        const closeBtn = document.createElement("button");
                        closeBtn.type = "button";
                        closeBtn.className = "browser-tab-close btn btn-sm btn-light border-0";
                        closeBtn.title = "关闭 TAB";
                        closeBtn.setAttribute("aria-label", "关闭 TAB");
                        closeBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                        closeBtn.addEventListener("click", async e => {
                            e.stopPropagation();
                            try {
                                applyStatus(await postJson("/Browser/CloseTab", { tabId: tab.id }));
                            } catch (e) {
                                showError(e.message || "关闭标签页失败。");
                            }
                        });

                        tabItem.appendChild(btn);
                        tabItem.appendChild(closeBtn);
                        groupTabs.appendChild(tabItem);
                    }

                    groupContainer.appendChild(groupHeader);
                    groupContainer.appendChild(groupTabs);
                    tabsBar.appendChild(groupContainer);
                }

                updateTabScrollButtons();
            }

            function renderTabsStatus(tabs) {
                tabsStatusPanel.replaceChildren();

                const header = document.createElement("div");
                header.className = "tabs-status-header";

                const title = document.createElement("div");
                title.className = "tabs-status-title";
                title.textContent = "TAB 状态";
                header.appendChild(title);

                // per-instance New TAB buttons are rendered inside each instance group;
                // remove global "新建 TAB" button from tabs status header to avoid confusion when no instances exist.

                tabsStatusPanel.appendChild(header);

                if (!tabs.length) {
                    const empty = document.createElement("div");
                    empty.className = "tabs-status-empty";
                    empty.textContent = "暂无 TAB";
                    const cta = document.createElement("div");
                    cta.className = "mt-3";
                    const ctaBtn = document.createElement("button");
                    ctaBtn.type = "button";
                    ctaBtn.className = "btn btn-sm btn-primary";
                    ctaBtn.innerHTML = '<i class="fa-solid fa-plus me-1"></i> 新建 实例';
                    ctaBtn.addEventListener('click', () => {
                        const createModalEl = document.getElementById('createInstanceModal');
                        if (createModalEl) {
                            const modal = new bootstrap.Modal(createModalEl);
                            modal.show();
                    // fetch preview path and show as placeholder in input
                    (async () => {
                        try {
                            const owner = document.getElementById('createInstanceOwnerPluginId')?.value || 'ui';
                            const resp = await (await fetch('/Browser/PreviewNewInstance?ownerPluginId=' + encodeURIComponent(owner))).json();
                            const previewPath = resp?.userDataDirectory || '';
                            const previewId = resp?.instanceId || '';
                            const input = document.getElementById('createInstanceUserDataDirectory');
                            const previewDiv = document.getElementById('createInstancePreview');
                            const previewNameEl = document.getElementById('createInstancePreviewName');
                            const previewPathEl = document.getElementById('createInstancePreviewPath');
                            if (input) {
                                input.placeholder = previewPath;
                                input.dataset.previewPath = previewPath; // keep for later
                                input.dataset.previewId = previewId;
                                input.classList.add('placeholder-italic');
                            }
                            if (previewDiv && previewPathEl && previewNameEl) {
                                previewDiv.style.display = '';
                                previewNameEl.querySelector('span').textContent = resp?.instanceId || '(生成中)';
                                previewPathEl.querySelector('span').textContent = previewPath || '(默认)';
                            }
                        } catch (e) { /* ignore preview errors */ }
                    })();
                        }
                    });
                    empty.appendChild(cta);
                    tabsStatusPanel.appendChild(empty);
                    return;
                }

                for (const group of groupTabsByInstance(tabs)) {
                    const groupCard = document.createElement("div");
                    groupCard.className = "tabs-instance-group";
                    groupCard.style.setProperty("--instance-color", group.instanceColor);

                    const groupHeader = document.createElement("div");
                    groupHeader.className = "tabs-instance-group-header";

                    const groupTitle = document.createElement("div");
                    groupTitle.className = "tabs-instance-group-title";
                    groupTitle.textContent = group.instanceName;
                    groupHeader.appendChild(groupTitle);

                    const groupActions = document.createElement("div");
                    groupActions.className = "tabs-status-actions";

                    const settingsInstanceBtn = document.createElement("button");
                    settingsInstanceBtn.type = "button";
                    settingsInstanceBtn.className = "btn btn-sm btn-outline-secondary tabs-status-close";
                    settingsInstanceBtn.title = "实例设置";
                    settingsInstanceBtn.setAttribute("aria-label", "实例设置");
                    settingsInstanceBtn.innerHTML = '<i class="fa-solid fa-sliders"></i>';
                    settingsInstanceBtn.addEventListener("click", async e => {
                        e.stopPropagation();
                        await openInstanceSettings(group.instanceId, group.instanceName);
                    });
                    groupActions.appendChild(settingsInstanceBtn);

                    const groupBadge = document.createElement("span");
                    groupBadge.className = "badge rounded-pill " + (group.isSelected ? "text-bg-primary" : "text-bg-secondary");
                    groupBadge.textContent = group.isSelected ? "当前实例" : "独立实例";
                    groupActions.appendChild(groupBadge);

                    const closeInstanceBtn = document.createElement("button");
                    closeInstanceBtn.type = "button";
                    closeInstanceBtn.className = "btn btn-sm btn-outline-secondary tabs-status-close";
                    closeInstanceBtn.title = "关闭整个实例";
                    closeInstanceBtn.setAttribute("aria-label", "关闭整个实例");
                    closeInstanceBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                    closeInstanceBtn.addEventListener("click", async e => {
                        e.stopPropagation();
                        try {
                            await closeInstance(group.instanceId);
                        } catch (e) {
                            showError(e.message || "关闭实例失败。");
                        }
                    });
                    groupActions.appendChild(closeInstanceBtn);

                    // 新建 TAB 按钮（在实例内部创建标签页）
                    const instanceNewTabBtn = document.createElement("button");
                    instanceNewTabBtn.type = "button";
                    instanceNewTabBtn.className = "btn btn-sm btn-outline-primary ms-2";
                    instanceNewTabBtn.title = "在此实例中新建 TAB";
                    instanceNewTabBtn.setAttribute("aria-label", "在此实例中新建 TAB");
                    instanceNewTabBtn.innerHTML = '<i class="fa-solid fa-plus"></i> 新建 TAB';
                    instanceNewTabBtn.addEventListener("click", async e => {
                        e.stopPropagation();
                        clearError();
                        try {
                            await postJson('/Browser/NewTab', { instanceId: group.instanceId, url: urlInput.value.trim() || null });
                            await refreshStatus();
                        } catch (err) {
                            showError(err.message || '在实例中新建标签页失败。');
                        }
                    });
                    groupActions.appendChild(instanceNewTabBtn);

                    groupHeader.appendChild(groupActions);

                    groupCard.appendChild(groupHeader);

                    for (const tab of group.tabs) {
                        const card = document.createElement("div");
                        card.className = "tabs-status-card" + (tab.isSelected ? " tabs-status-card-active" : "");
                        card.tabIndex = 0;
                        card.setAttribute("role", "button");
                        card.setAttribute("aria-label", "切换到 TAB: " + (tab.title || tab.url || "about:blank"));
                        card.addEventListener("click", async () => {
                            try {
                                await selectTab(tab.id);
                            } catch (e) {
                                showError(e.message || "切换标签页失败。");
                            }
                        });
                        card.addEventListener("keydown", async e => {
                            if (e.key !== "Enter" && e.key !== " ")
                                return;

                            e.preventDefault();
                            try {
                                await selectTab(tab.id);
                            } catch (e) {
                                showError(e.message || "切换标签页失败。");
                            }
                        });

                        const row = document.createElement("div");
                        row.className = "tabs-status-row";

                        const heading = document.createElement("div");
                        heading.className = "tabs-status-name";
                        heading.textContent = tab.title || "(无标题)";
                        row.appendChild(heading);

                        const actions = document.createElement("div");
                        actions.className = "tabs-status-actions";

                        const badge = document.createElement("span");
                        badge.className = "badge rounded-pill " + (tab.isSelected ? "text-bg-primary" : "text-bg-secondary");
                        badge.textContent = tab.isSelected ? "当前" : "后台";
                        actions.appendChild(badge);

                        const closeBtn = document.createElement("button");
                        closeBtn.type = "button";
                        closeBtn.className = "btn btn-sm btn-outline-secondary tabs-status-close";
                        closeBtn.title = "关闭 TAB";
                        closeBtn.setAttribute("aria-label", "关闭 TAB");
                        closeBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                        closeBtn.addEventListener("click", async e => {
                            e.stopPropagation();
                            try {
                                applyStatus(await postJson("/Browser/CloseTab", { tabId: tab.id }));
                            } catch (e) {
                                showError(e.message || "关闭标签页失败。");
                            }
                        });
                        actions.appendChild(closeBtn);

                        row.appendChild(actions);

                        card.appendChild(row);

                        const url = document.createElement("div");
                        url.className = "tabs-status-url";
                        url.textContent = tab.url || "about:blank";
                        card.appendChild(url);

                        groupCard.appendChild(card);
                    }

                    tabsStatusPanel.appendChild(groupCard);
                }
            }

            function updateTabScrollButtons() {
                const maxScrollLeft = Math.max(0, tabsBar.scrollWidth - tabsBar.clientWidth);
                tabsScrollLeftBtn.disabled = tabsBar.scrollLeft <= 0;
                tabsScrollRightBtn.disabled = tabsBar.scrollLeft >= maxScrollLeft - 1;
            }

            async function refreshStatus() {
                if (statusBusy) return;
                statusBusy = true;
                try {
                    const response = await fetch("/Browser/Status");
                    if (!response.ok)
                        throw new Error("状态获取失败: " + response.status);

                    applyStatus(await response.json());
                } catch (e) {
                    showError(e.message || "状态获取失败。");
                } finally {
                    statusBusy = false;
                }
            }

            async function loadPlugins() {
                try {
                    const response = await fetch("/Browser/Plugins");
                    if (!response.ok)
                        throw new Error("插件列表获取失败: " + response.status);

                    const payload = await response.json();
                    const plugins = Array.isArray(payload) ? payload : (payload.plugins || []);
                    const errors = Array.isArray(payload?.errors) ? payload.errors.filter(Boolean) : [];

                    renderPlugins(plugins);

                    if (errors.length)
                        showError(errors.join("； "));
                } catch (e) {
                    pluginHost.replaceChildren();
                    const error = document.createElement("div");
                    error.className = "text-danger";
                    error.textContent = e.message || "插件列表获取失败。";
                    pluginHost.appendChild(error);
                }
            }

            async function runAction(action, fallbackMessage) {
                try {
                    applyStatus(await action());
                } catch (e) {
                    showError(e.message || fallbackMessage);
                }
            }

            async function navigate() {
                await runAction(() => postJson("/Browser/Navigate", { url: urlInput.value.trim() }), "导航失败。");
                isEditingUrl = false;
                urlInput.blur();
            }

            async function previewScreenshot() {
                shotBtn.disabled = true;
                clearError();

                try {
                    const response = await fetch("/Browser/Screenshot?ts=" + Date.now(), { cache: "no-store" });
                    if (!response.ok)
                        throw new Error("截图失败: " + response.status);

                    const blob = await response.blob();
                    if (screenshotPreviewUrl)
                        URL.revokeObjectURL(screenshotPreviewUrl);

                    screenshotPreviewUrl = URL.createObjectURL(blob);
                    screenshotPreviewImage.src = screenshotPreviewUrl;
                    screenshotPreviewModal.show();
                } catch (e) {
                    showError(e.message || "截图失败。");
                } finally {
                    shotBtn.disabled = false;
                }
            }

            function intervalToFps(intervalMs) {
                const interval = Math.max(16, Number(intervalMs) || 100);
                return Math.max(1, Math.min(60, Math.round(1000 / interval)));
            }

            function fpsToInterval(fps) {
                const normalized = Math.max(1, Math.min(60, Number(fps) || 10));
                return Math.max(16, Math.round(1000 / normalized));
            }

            function getCanvasViewportSize() {
                const width = Math.max(320, Math.round(browserStage?.clientWidth || canvas.clientWidth || 1280));
                const height = Math.max(240, Math.round(browserStage?.clientHeight || canvas.clientHeight || 800));
                return { width, height };
            }

            function resizeCanvasBuffer(width, height) {
                if (canvas.width !== width || canvas.height !== height) {
                    canvas.width = width;
                    canvas.height = height;
                }
            }

            async function syncScreencastSettings(force = false) {
                const viewport = getCanvasViewportSize();
                resizeCanvasBuffer(viewport.width, viewport.height);

                if (applyingScreencastSettings) {
                    pendingScreencastSync = true;
                    return;
                }

                applyingScreencastSettings = true;
                try {
                    applyStatus(await postJson("/Browser/Screencast", {
                        enabled: liveDisplayEnabled,
                        maxWidth: viewport.width,
                        maxHeight: viewport.height,
                        frameIntervalMs: targetFrameIntervalMs
                    }));
                    hideTemporaryCanvasOverlay();
                } catch (e) {
                    if (force)
                        showError(e.message || "画面设置更新失败。");
                } finally {
                    applyingScreencastSettings = false;
                    const needsAnotherSync = pendingScreencastSync;
                    pendingScreencastSync = false;
                    if (needsAnotherSync)
                        scheduleScreencastSync();
                }
            }

            function scheduleScreencastSync(force = false) {
                if (resizeSyncTimer)
                    clearTimeout(resizeSyncTimer);

                resizeSyncTimer = setTimeout(() => {
                    syncScreencastSettings(force).catch(() => { });
                }, force ? 0 : 150);
            }

            urlInput.addEventListener("focus", () => isEditingUrl = true);
            urlInput.addEventListener("blur", () => isEditingUrl = false);
            browserPaneDivider.addEventListener("pointerdown", e => {
                if (!beginPanelResize())
                    return;

                e.preventDefault();
                browserPaneDivider.setPointerCapture(e.pointerId);
                updatePanelResize(e.clientX);
            });
            browserPaneDivider.addEventListener("pointermove", e => updatePanelResize(e.clientX));
            browserPaneDivider.addEventListener("pointerup", () => endPanelResize(true));
            browserPaneDivider.addEventListener("pointercancel", () => endPanelResize(false));
            browserPaneDivider.addEventListener("keydown", e => {
                const step = e.shiftKey ? 20 : 10;
                if (e.key !== "ArrowLeft" && e.key !== "ArrowRight")
                    return;

                e.preventDefault();
                applyPluginPanelWidth(pluginPanelWidth + (e.key === "ArrowLeft" ? step : -step));
                savePluginPanelWidth(pluginPanelWidth).catch(() => { });
            });
            instanceViewportWidthInput.addEventListener("input", () => {
                if (!synchronizingAspectRatio)
                    refreshInstanceSettingsAspectRatio();
                syncInstanceHeightFromWidth();
            });
            instanceViewportHeightInput.addEventListener("input", () => {
                if (!synchronizingAspectRatio)
                    refreshInstanceSettingsAspectRatio();
                syncInstanceWidthFromHeight();
            });
            instancePreserveAspectRatioInput.addEventListener("change", () => {
                refreshInstanceSettingsAspectRatio();
                syncInstanceHeightFromWidth();
            });
            instanceUseProgramUserAgentInput.addEventListener("change", syncInstanceUserAgentEditorState);
            liveToggleBtn.addEventListener("click", () => {
                if (!screencastAvailable)
                    return;

                setLiveDisplayEnabled(!liveDisplayEnabled);
                syncScreencastSettings(true).catch(() => { });
            });

            newInstanceBtn?.addEventListener("click", async () => {
                clearError();
                // show create instance modal
                const createModalEl = document.getElementById('createInstanceModal');
                if (createModalEl) {
                    const modal = new bootstrap.Modal(createModalEl);
                    modal.show();
                }
            });

            // Create instance modal submit
            const createInstanceSubmitBtn = document.getElementById('createInstanceSubmitBtn');
            createInstanceSubmitBtn?.addEventListener('click', async () => {
                clearError();
                const ownerPluginId = document.getElementById('createInstanceOwnerPluginId')?.value || 'ui';
                const displayName = document.getElementById('createInstanceDisplayName')?.value || null;
                const userDataInput = document.getElementById('createInstanceUserDataDirectory');
                const userDataDirectory = (userDataInput && (userDataInput.value || '').trim()) || null;

                const payload = { ownerPluginId, displayName, userDataDirectory };
                // if user left the directory empty and a preview id is available, send it so backend can honor the preview id
                if (!userDataDirectory && userDataInput && userDataInput.dataset && userDataInput.dataset.previewId)
                    payload.previewInstanceId = userDataInput.dataset.previewId;

                try {
                    const res = await postJson('/Browser/CreateInstance', payload);
                    const modal = bootstrap.Modal.getInstance(document.getElementById('createInstanceModal'));
                    modal?.hide();
                    const previewDiv = document.getElementById('createInstancePreview');
                    if (previewDiv) previewDiv.style.display = 'none';

                    // Refresh status after creating instance; handle transient 405/other unexpected responses gracefully
                    try {
                        await refreshStatus();
                    } catch (e) {
                        // If creation succeeded but status failed, still try to call Status again after short delay
                        showError((e && e.message) || '状态获取失败，稍后重试。', 'warning');
                        setTimeout(async () => {
                            try { await refreshStatus(); } catch (ex) { console.warn('Status retry failed', ex); }
                        }, 800);
                    }
                } catch (e) {
                    showError(e.message || '创建实例失败。');
                }
            });
            tabsBar.addEventListener("scroll", updateTabScrollButtons);
            tabsScrollLeftBtn.addEventListener("click", () => tabsBar.scrollBy({ left: -240, behavior: "smooth" }));
            tabsScrollRightBtn.addEventListener("click", () => tabsBar.scrollBy({ left: 240, behavior: "smooth" }));

            if (window.ResizeObserver && browserStage) {
                const resizeObserver = new ResizeObserver(() => {
                    scheduleCurrentInstanceViewportSync();
                    if (!liveDisplayEnabled)
                        return;
                    showCanvasOverlay("Resetting Canvas", true);
                    scheduleScreencastSync();
                });
                resizeObserver.observe(browserStage);
            } else {
                window.addEventListener("resize", () => {
                    scheduleCurrentInstanceViewportSync();
                    if (!liveDisplayEnabled)
                        return;
                    showCanvasOverlay("Resetting Canvas", true);
                    scheduleScreencastSync();
                });
            }

            setLiveDisplayEnabled(true);
            renderFpsDisplay();
            applyPluginPanelWidth(pluginPanelWidth);
            const initialViewport = getCanvasViewportSize();
            resizeCanvasBuffer(initialViewport.width, initialViewport.height);

            const newTabBtnEl = document.getElementById("newTabBtn");
            if (newTabBtnEl)
                newTabBtnEl.addEventListener("click", async () => runAction(() => postJson("/Browser/NewTab"), "新建标签页失败。"));
            document.getElementById("backBtn").addEventListener("click", async () => runAction(() => postJson("/Browser/Back"), "后退失败。"));
            document.getElementById("forwardBtn").addEventListener("click", async () => runAction(() => postJson("/Browser/Forward"), "前进失败。"));
            document.getElementById("reloadBtn").addEventListener("click", async () => runAction(() => postJson("/Browser/Reload"), "刷新失败。"));
            document.getElementById("goBtn").addEventListener("click", navigate);
            urlInput.addEventListener("keydown", async e => {
                if (e.key !== "Enter") return;
                e.preventDefault();
                await navigate();
            });

            shotBtn.addEventListener("click", previewScreenshot);

            setInterval(() => {
                refreshStatus().catch(() => {});
            }, 2000);

            // input forwarding now handled by browser-input.js module
            if (window.BrowserInput && typeof window.BrowserInput.init === 'function') {
                try { window.BrowserInput.init(conn, canvas); } catch (e) { console.warn('BrowserInput init failed', e); }
            }

        }());
    </script>
}
