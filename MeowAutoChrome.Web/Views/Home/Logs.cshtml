@model MeowAutoChrome.Web.Models.LogPageViewModel
@{
    ViewData["Title"] = "运行日志";
    var initialEntriesJson = System.Text.Json.JsonSerializer.Serialize(Model.Entries, new System.Text.Json.JsonSerializerOptions
    {
        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
    });
}

<div class="container-fluid px-0 logs-page">
    <div class="vstack gap-3">
        <div class="settings-page-header">
            <div>
                <h1 class="h4 mb-1">运行日志</h1>
                <div class="text-muted small">显示最近的程序输出，来源于 `@Model.LogDisplayPath`。</div>
            </div>
            <div class="settings-toolbar">
                <span id="logsLastUpdated" class="text-muted small">@(Model.LastUpdatedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "暂无日志")</span>
                <label class="form-check form-switch mb-0">
                    <input id="logsAutoRefresh" class="form-check-input" type="checkbox" checked />
                    <span class="form-check-label small">自动刷新</span>
                </label>
                <button id="refreshLogsButton" type="button" class="btn btn-outline-secondary btn-sm">刷新</button>
                <form asp-action="ClearLogs" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">清空日志</button>
                </form>
            </div>
        </div>

        <section class="card shadow-sm settings-card logs-card">
            <div class="card-header fw-semibold">最新日志</div>
            <div class="card-body border-bottom bg-light-subtle">
                <div class="log-filter-bar">
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <span class="text-muted small">级别筛选</span>
                        <label class="form-check form-check-inline mb-0">
                            <input class="form-check-input" type="checkbox" value="info" data-log-filter checked />
                            <span class="form-check-label">Info</span>
                        </label>
                        <label class="form-check form-check-inline mb-0">
                            <input class="form-check-input" type="checkbox" value="warn" data-log-filter checked />
                            <span class="form-check-label">Warn</span>
                        </label>
                        <label class="form-check form-check-inline mb-0">
                            <input class="form-check-input" type="checkbox" value="error" data-log-filter checked />
                            <span class="form-check-label">Error</span>
                        </label>
                    </div>
                    <span id="logsSummary" class="text-muted small"></span>
                </div>
            </div>
            <div class="card-body p-0 logs-card-body">
                <div id="logViewer" class="log-viewer mb-0"></div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const autoRefreshCheckbox = document.getElementById("logsAutoRefresh");
            const refreshButton = document.getElementById("refreshLogsButton");
            const logViewer = document.getElementById("logViewer");
            const lastUpdated = document.getElementById("logsLastUpdated");
            const logsSummary = document.getElementById("logsSummary");
            const logsContentUrl = "@Url.Action("LogsContent", "Home")";
            const filterCheckboxes = Array.from(document.querySelectorAll("[data-log-filter]"));
            const autoRefreshIntervalMs = 3000;
            const logsViewStateStorageKey = "meowautochrome.logs.view-state";
            let autoRefreshTimer = null;
            let logEntries = @Html.Raw(initialEntriesJson);

            function loadViewState() {
                try {
                    return JSON.parse(localStorage.getItem(logsViewStateStorageKey) || "null");
                } catch {
                    return null;
                }
            }

            function saveViewState() {
                try {
                    localStorage.setItem(logsViewStateStorageKey, JSON.stringify({
                        autoRefresh: autoRefreshCheckbox.checked,
                        filters: Object.fromEntries(filterCheckboxes.map(checkbox => [checkbox.value, checkbox.checked]))
                    }));
                } catch {
                }
            }

            function restoreViewState() {
                const state = loadViewState();
                if (!state)
                    return;

                if (typeof state.autoRefresh === "boolean")
                    autoRefreshCheckbox.checked = state.autoRefresh;

                const filters = state.filters || {};
                filterCheckboxes.forEach(checkbox => {
                    if (typeof filters[checkbox.value] === "boolean")
                        checkbox.checked = filters[checkbox.value];
                });
            }

            function scrollToBottom() {
                logViewer.scrollTop = logViewer.scrollHeight;
            }

            function isNearBottom() {
                return logViewer.scrollHeight - logViewer.scrollTop - logViewer.clientHeight < 24;
            }

            function getSelectedLevels() {
                return new Set(filterCheckboxes.filter(checkbox => checkbox.checked).map(checkbox => checkbox.value));
            }

            function renderLogs(options) {
                const settings = options || {};
                const keepBottom = settings.keepBottom ?? false;
                const wasNearBottom = isNearBottom();
                const selectedLevels = getSelectedLevels();
                const visibleEntries = logEntries.filter(entry => selectedLevels.has(entry.filterLevel));

                logViewer.replaceChildren();

                if (visibleEntries.length === 0) {
                    const emptyState = document.createElement("div");
                    emptyState.className = "log-entry-empty";
                    emptyState.textContent = "当前筛选条件下没有日志。";
                    logViewer.appendChild(emptyState);
                } else {
                    for (const entry of visibleEntries) {
                        const item = document.createElement("div");
                        item.className = "log-entry log-entry-" + entry.filterLevel;

                        const meta = document.createElement("div");
                        meta.className = "log-entry-meta";

                        const timestamp = document.createElement("span");
                        timestamp.className = "log-entry-timestamp";
                        timestamp.textContent = entry.timestampText;
                        meta.appendChild(timestamp);

                        const badge = document.createElement("span");
                        badge.className = "log-entry-badge log-entry-badge-" + entry.filterLevel;
                        badge.textContent = entry.levelText;
                        meta.appendChild(badge);

                        const category = document.createElement("span");
                        category.className = "log-entry-category";
                        category.textContent = entry.category;
                        meta.appendChild(category);

                        const message = document.createElement("div");
                        message.className = "log-entry-message";
                        message.textContent = entry.message;

                        item.appendChild(meta);
                        item.appendChild(message);
                        logViewer.appendChild(item);
                    }
                }

                logsSummary.textContent = `显示 ${visibleEntries.length} / ${logEntries.length} 行`;

                if (keepBottom || wasNearBottom)
                    scrollToBottom();
            }

            function updateAutoRefresh() {
                if (autoRefreshTimer) {
                    clearInterval(autoRefreshTimer);
                    autoRefreshTimer = null;
                }

                if (autoRefreshCheckbox.checked) {
                    autoRefreshTimer = setInterval(() => {
                        refreshLogs({ silent: true }).catch(() => { });
                    }, autoRefreshIntervalMs);
                }
            }

            async function refreshLogs(options) {
                const settings = options || {};
                const silent = settings.silent ?? false;

                if (!silent)
                    refreshButton.disabled = true;

                try {
                    const response = await fetch(logsContentUrl, {
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });

                    if (!response.ok)
                        return;

                    const payload = await response.json();
                    logEntries = payload.entries || [];
                    lastUpdated.textContent = payload.lastUpdatedLocal || "暂无日志";
                    renderLogs({ keepBottom: true });
                } finally {
                    refreshButton.disabled = false;
                }
            }

            refreshButton.addEventListener("click", () => {
                refreshLogs().catch(() => { });
            });

            autoRefreshCheckbox.addEventListener("change", () => {
                saveViewState();
                updateAutoRefresh();
            });

            filterCheckboxes.forEach(checkbox => {
                checkbox.addEventListener("change", () => {
                    saveViewState();
                    renderLogs();
                });
            });

            restoreViewState();
            renderLogs({ keepBottom: true });
            updateAutoRefresh();
        })();
    </script>
}
