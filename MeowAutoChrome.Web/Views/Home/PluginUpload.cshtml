@{
    ViewData["Title"] = "插件上传与管理";
    Layout = "_Layout";
}

<div class="d-flex align-items-start gap-4">
    <div class="flex-shrink-0" style="width:520px;">
        <h2 class="h4 mb-3">插件上传与管理</h2>
        <div class="card">
            <div class="card-body">
                <div id="uploadDropZone" class="border rounded p-3 mb-3" style="min-height:140px; display:flex; align-items:center;">
                    <div class="w-100">
                        <label class="form-label fw-semibold">选择要上传的插件文件或文件夹</label>
                        <div class="small text-muted mb-2">支持 DLL、ZIP。Chrome/Chromium 支持目录上传。也可将插件目录打包为 ZIP 后上传以兼容更多浏览器。</div>
                        <input id="pluginUploadInput" type="file" webkitdirectory directory multiple accept=".dll,.zip" class="form-control mb-2" />
                        <div class="d-flex gap-2">
                            <button id="pluginUploadBtn" class="btn btn-primary">上传并扫描</button>
                            <button id="pluginClearBtn" type="button" class="btn btn-outline-secondary">清除选择</button>
                            <div id="uploadSpinner" class="spinner-border text-primary" role="status" style="display:none; width:1.2rem; height:1.2rem;"></div>
                        </div>
                        <div id="uploadHint" class="form-text small text-muted mt-2">提示：请选择 DLL 或 ZIP 文件，或直接选择包含 DLL 的文件夹（仅在支持的浏览器中可用）。</div>
                    </div>
                </div>

<!-- Confirm modal for destructive actions -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalTitle">确认</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="confirmModalBody">确认操作？</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button id="confirmModalOk" type="button" class="btn btn-danger">确认删除</button>
            </div>
        </div>
    </div>
</div>
                <div id="selectedFilesInfo" class="small text-muted">尚未选择文件。</div>
            </div>
        </div>
    </div>

    <div class="flex-grow-1">
        <h2 class="h5 mb-3">扫描结果</h2>
        <div id="uploadResult" class="card" style="min-height:160px;">
            <div class="card-body">
                <div id="resultPlaceholder" class="text-muted">上传并扫描后，这里会显示每个 DLL 的解析结果（仅会注册带 <code>[Plugin(...)]</code> 标注的类型）。</div>
                <div id="resultList" class="accordion" style="margin-top:8px;"></div>
            </div>
        </div>

        <h2 class="h5 mt-4 mb-3">已安装插件</h2>
        <div id="installedPlugins" class="card">
            <div class="card-body">
                <div id="installedPlaceholder" class="text-muted">正在加载已安装插件列表…</div>
                <div id="installedList" class="list-group" style="margin-top:8px;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/plugin-upload.js" asp-append-version="true"></script>
}
