@using MeowAutoChrome.Core
@model MeowAutoChrome.Web.Models.ProgramSettingsViewModel
@{
    ViewData["Title"] = "程序设置";
}

<div class="container-fluid px-0 settings-page-shell">
    <div class="settings-page">
        <aside class="settings-sidebar">
            <div class="card shadow-sm settings-sidebar-card">
                <div class="card-header fw-semibold">设置导航</div>
                <div class="card-body vstack gap-2">
                    <a class="settings-nav-link settings-nav-link-primary" asp-action="Settings">程序设置</a>
                    <a class="settings-nav-link" asp-action="CustomSettings">自定义设置（高级）</a>
                    <div id="settingsNavLinks" class="vstack gap-2"></div>
                </div>
            </div>
        </aside>

        <div class="settings-content">
            <div class="settings-page-header">
                <div>
                    <h1 class="h4 mb-1">程序设置</h1>
                    <div class="text-muted small">修改后会自动保存并立即应用。</div>
                    <div class="text-muted small">设置文件位置：<code>@ProgramSettings.GetSettingsFilePath()</code></div>
                </div>
                <div id="settingsAutoSaveStatus" class="settings-autosave-status settings-autosave-status-success">已加载设置</div>
                <div id="pageNotifications" class="toast-container p-3 position-fixed top-0 end-0" style="z-index:1050"></div>
            </div>

            <form id="settingsForm" asp-action="AutoSaveSettings" method="post" class="settings-card-stack">
                @Html.AntiForgeryToken()

                <section id="searchSettingsCard" class="card shadow-sm settings-card">
                    <div class="card-header fw-semibold">搜索设置</div>
                    <div class="card-body">
                        <label asp-for="SearchUrlTemplate" class="form-label"></label>
                        <input asp-for="SearchUrlTemplate" class="form-control" placeholder="https://www.baidu.com/s?wd={query}" />
                        <div class="form-text">当地址栏输入内容不是网址时，会使用这个模板进行搜索。必须包含 <code>{query}</code> 占位符。</div>
                        <span asp-validation-for="SearchUrlTemplate" class="text-danger"></span>
                    </div>
                    <div class="card-body">
                        <p>模板示例</p>
                        <div><code>https://www.baidu.com/s?wd={query}</code></div>
                        <div><code>https://www.google.com/search?q={query}</code></div>
                        <div><code>https://www.bing.com/search?q={query}</code></div>
                    </div>
                </section>

                <!-- 自定义设置已移至单独页面：Home/CustomSettings -->

                <section id="screencastSettingsCard" class="card shadow-sm settings-card">
                    <div class="card-header fw-semibold">实时画面</div>
                    <div class="card-body">
                        <label asp-for="ScreencastFps" class="form-label">推流 FPS</label>
                        <input asp-for="ScreencastFps" type="number" min="1" max="60" class="form-control" />
                        <div class="form-text">设置浏览器实时画面的目标推流 FPS。</div>
                        <span asp-validation-for="ScreencastFps" class="text-danger"></span>
                    </div>
                </section>

                <section id="profileSettingsCard" class="card shadow-sm settings-card">
                    <div class="card-header fw-semibold">浏览器用户数据</div>
                    <div class="card-body">
                        <label asp-for="UserDataDirectory" class="form-label"></label>
                        <input asp-for="UserDataDirectory" class="form-control" placeholder="@ProgramSettings.GetDefaultUserDataDirectoryPath()" />
                        <div class="form-text">
                            默认目录：<code>@ProgramSettings.GetDefaultUserDataDirectoryPath()</code>。<br />
                            修改后会尝试把当前目录中已有的浏览器用户数据迁移到新目录。
                        </div>
                        <span asp-validation-for="UserDataDirectory" class="text-danger"></span>
                    </div>
                    <div class="card-body border-top">
                        <div class="form-check form-switch">
                            <input asp-for="Headless" class="form-check-input" />
                            <label asp-for="Headless" class="form-check-label"></label>
                        </div>
                        <div class="form-text">关闭后会显示真实 Chrome 窗口，并自动禁用实时查看功能。</div>
                        <span asp-validation-for="Headless" class="text-danger"></span>
                    </div>
                </section>

                <section id="userAgentSettingsCard" class="card shadow-sm settings-card">
                    <div class="card-header fw-semibold">User-Agent</div>
                    <div class="card-body">
                        <label asp-for="UserAgent" class="form-label"></label>
                        <textarea asp-for="UserAgent" class="form-control" rows="3" placeholder="留空时使用浏览器默认 User-Agent"></textarea>
                        <div class="form-text">这里设置后会作为程序级默认 UA。留空则不强制注入全局 UA。</div>
                        <span asp-validation-for="UserAgent" class="text-danger"></span>
                    </div>
                    <div class="card-body border-top">
                        <div class="form-check form-switch">
                            <input asp-for="AllowInstanceUserAgentOverride" class="form-check-input" />
                            <label asp-for="AllowInstanceUserAgentOverride" class="form-check-label"></label>
                        </div>
                        <div class="form-text">默认关闭。关闭后，只要程序设置了全局 UA，实例设置里就不能再单独覆盖。</div>
                        <span asp-validation-for="AllowInstanceUserAgentOverride" class="text-danger"></span>
                    </div>
                </section>

                <section id="layoutSettingsCard" class="card shadow-sm settings-card">
                    <div class="card-header fw-semibold">界面布局</div>
                    <div class="card-body">
                        <label asp-for="PluginPanelWidth" class="form-label"></label>
                        <input asp-for="PluginPanelWidth"
                               type="range"
                               min="@ProgramSettings.MinPluginPanelWidth"
                               max="@ProgramSettings.MaxPluginPanelWidth"
                               class="form-range" />
                        <div class="d-flex justify-content-between align-items-center small text-muted">
                            <span>浏览器区与插件区之间分隔条的默认位置。</span>
                            <span id="pluginPanelWidthValue">@Model.PluginPanelWidth px</span>
                        </div>
                        <span asp-validation-for="PluginPanelWidth" class="text-danger"></span>
                    </div>
                </section>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.getElementById("settingsForm");
            const status = document.getElementById("settingsAutoSaveStatus");
            const navLinks = document.getElementById("settingsNavLinks");
            const fields = form.querySelectorAll("input, textarea, select");
            const pluginPanelWidthInput = document.getElementById("PluginPanelWidth");
            const pluginPanelWidthValue = document.getElementById("pluginPanelWidthValue");
            let saveTimer = null;
            let activeRequest = null;
            let lastSavedState = new URLSearchParams(new FormData(form)).toString();

            function buildSettingsNav() {
                navLinks.replaceChildren();

                form.querySelectorAll("section.settings-card").forEach((section, index) => {
                    if (!section.id)
                        section.id = "settingsSection" + (index + 1);

                    const title = section.querySelector(".card-header.fw-semibold")?.textContent?.trim();
                    if (!title)
                        return;

                    const link = document.createElement("a");
                    link.className = "settings-nav-link";
                    link.href = "#" + section.id;
                    link.textContent = title;
                    navLinks.appendChild(link);
                });
            }

            function setStatus(message, kind) {
                status.textContent = message;
                status.className = "settings-autosave-status settings-autosave-status-" + kind;
            }

            async function saveSettings() {
                const state = new URLSearchParams(new FormData(form)).toString();
                if (state === lastSavedState) {
                    setStatus("已自动保存", "success");
                    return;
                }

                activeRequest?.abort();
                activeRequest = new AbortController();
                setStatus("正在自动保存...", "saving");

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: new FormData(form),
                        headers: { "X-Requested-With": "XMLHttpRequest" },
                        signal: activeRequest.signal
                    });

                    const payload = await response.json().catch(() => ({ message: "设置保存失败。" }));
                    if (!response.ok) {
                        setStatus(payload.message || "设置保存失败。", "error");
                        showNotification(payload.message || "设置保存失败。", 'danger');
                        return;
                    }

                    lastSavedState = state;
                    setStatus(payload.message || "设置已自动保存。", "success");
                    showNotification(payload.message || "设置已自动保存。", 'success');
                } catch (error) {
                    if (error.name === "AbortError")
                        return;

                    setStatus("设置保存失败。", "error");
                    showNotification('设置保存失败。', 'danger');
                }
            }

            function scheduleSave() {
                clearTimeout(saveTimer);
                setStatus("检测到变更...", "saving");
                saveTimer = setTimeout(() => { saveSettings().catch(() => { }); }, 500);
            }

            function renderPluginPanelWidth() {
                if (!pluginPanelWidthInput || !pluginPanelWidthValue)
                    return;

                pluginPanelWidthValue.textContent = pluginPanelWidthInput.value + " px";
            }

            fields.forEach(field => {
                field.addEventListener("input", scheduleSave);
                field.addEventListener("change", scheduleSave);
            });

            pluginPanelWidthInput?.addEventListener("input", renderPluginPanelWidth);
            pluginPanelWidthInput?.addEventListener("change", renderPluginPanelWidth);

            buildSettingsNav();
            renderPluginPanelWidth();
            renderCustomSettings();

                function renderCustomSettings() {
                const container = document.getElementById("customSettingsContainer");
                const existing = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.CustomSettings ?? new System.Collections.Generic.Dictionary<string, string?>()));
                container.replaceChildren();

                function addRow(key = '', value = '') {
                    const tr = document.createElement('tr');
                    tr.className = 'align-middle';

                    const handleTd = document.createElement('td');
                    handleTd.className = 'text-muted drag-handle';
                    handleTd.style.cursor = 'grab';
                    handleTd.innerHTML = '☰';

                    const keyTd = document.createElement('td');
                    const keyInput = document.createElement('input');
                    keyInput.name = 'CustomSettings.Keys';
                    keyInput.className = 'form-control form-control-sm';
                    keyInput.placeholder = 'Key';
                    keyInput.value = key;
                    keyTd.appendChild(keyInput);

                    const valTd = document.createElement('td');
                    const valInput = document.createElement('input');
                    valInput.name = 'CustomSettings.Values';
                    valInput.className = 'form-control form-control-sm';
                    valInput.placeholder = 'Value';
                    valInput.value = value;
                    valTd.appendChild(valInput);

                    const opTd = document.createElement('td');
                    const del = document.createElement('button');
                    del.type = 'button';
                    del.className = 'btn btn-sm btn-outline-danger';
                    del.textContent = '删除';
                    del.addEventListener('click', () => tr.remove());
                    opTd.appendChild(del);

                    tr.appendChild(handleTd);
                    tr.appendChild(keyTd);
                    tr.appendChild(valTd);
                    tr.appendChild(opTd);
                    container.appendChild(tr);
                }

                for (const [k, v] of Object.entries(existing)) {
                    addRow(k, v ?? '');
                }

                const addBtn = document.getElementById('addCustomSetting');
                addBtn?.addEventListener('click', () => addRow());

                const sortBtn = document.getElementById('sortCustomSettings');
                sortBtn?.addEventListener('click', () => {
                    const rows = Array.from(container.querySelectorAll('tr'));
                    rows.sort((a, b) => {
                        const ak = a.querySelector('input[name="CustomSettings.Keys"]')?.value ?? '';
                        const bk = b.querySelector('input[name="CustomSettings.Keys"]')?.value ?? '';
                        return ak.localeCompare(bk, undefined, { sensitivity: 'base' });
                    });
                    container.replaceChildren(...rows);
                });

                // Filtering
                const filterKey = document.getElementById('filterKey');
                const filterValue = document.getElementById('filterValue');
                function applyFilter() {
                    const k = (filterKey?.value || '').toLowerCase();
                    const v = (filterValue?.value || '').toLowerCase();
                    for (const row of container.querySelectorAll('tr')) {
                        const key = (row.querySelector('input[name="CustomSettings.Keys"]')?.value || '').toLowerCase();
                        const val = (row.querySelector('input[name="CustomSettings.Values"]')?.value || '').toLowerCase();
                        const matches = (k === '' || key.includes(k)) && (v === '' || val.includes(v));
                        (row as HTMLElement).style.display = matches ? '' : 'none';
                    }
                }
                filterKey?.addEventListener('input', applyFilter);
                filterValue?.addEventListener('input', applyFilter);

                // Simple drag-and-drop reordering for rows
                let dragSrc = null;
                container.addEventListener('dragstart', (e) => { if ((e.target as HTMLElement).closest('tr')) { dragSrc = (e.target as HTMLElement).closest('tr'); e.dataTransfer!.effectAllowed = 'move'; } });
                container.addEventListener('dragover', (e) => { e.preventDefault(); e.dataTransfer!.dropEffect = 'move'; });
                container.addEventListener('drop', (e) => {
                    e.preventDefault();
                    const tr = (e.target as HTMLElement).closest('tr');
                    if (!tr || !dragSrc || tr === dragSrc) return;
                    container.insertBefore(dragSrc, tr.nextSibling);
                });

                // make handle draggable
                container.querySelectorAll('.drag-handle').forEach(h => { const el = h as HTMLElement; el.setAttribute('draggable', 'true'); });

                // client-side validation before form submit
                const formEl = document.getElementById('settingsForm');
                formEl.addEventListener('submit', (e) => {
                    const keyInputs = container.querySelectorAll('input[name="CustomSettings.Keys"]');
                    const seen = new Set();
                    const invalidPattern = /[^A-Za-z0-9_.-]/;
                    for (const ki of keyInputs) {
                        const val = (ki.value || '').trim();
                        if (!val) { e.preventDefault(); showNotification('自定义设置的键不能为空。', 'danger'); return; }
                        if (invalidPattern.test(val)) { e.preventDefault(); showNotification('自定义键包含非法字符。', 'danger'); return; }
                        const lower = val.toLowerCase();
                        if (seen.has(lower)) { e.preventDefault(); showNotification('发现重复的自定义键：' + val, 'danger'); return; }
                        seen.add(lower);
                    }
                });

                function showNotification(message, kind = 'info', timeoutMs = 5000) {
                    const container = document.getElementById('pageNotifications');
                    // Map kinds to bootstrap contextual classes for toasts
                    const bg = kind === 'danger' ? 'danger' : (kind === 'success' ? 'success' : 'primary');

                    const toast = document.createElement('div');
                    toast.className = `toast align-items-center text-bg-${bg} border-0`;
                    toast.setAttribute('role', 'alert');
                    toast.setAttribute('aria-live', 'assertive');
                    toast.setAttribute('aria-atomic', 'true');

                    toast.innerHTML = `
                        <div class="d-flex">
                            <div class="toast-body">${message}</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>`;

                    container.appendChild(toast);
                    // Use Bootstrap's Toast JS to show and auto-hide
                    try {
                        const bsToast = bootstrap.Toast.getOrCreateInstance(toast, { delay: timeoutMs });
                        bsToast.show();
                        toast.addEventListener('hidden.bs.toast', () => toast.remove());
                    } catch (e) {
                        // Fallback: remove after timeout
                        setTimeout(() => toast.remove(), timeoutMs);
                    }
                }
            }
        })();
    </script>
}
