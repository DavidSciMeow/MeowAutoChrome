@{
    ViewData["Title"] = "插件管理";
    Layout = "_Layout";
}

<div class="container py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>插件管理</h4>
        <div>
            <button id="rescanBtn" class="btn btn-sm btn-outline-secondary">重新扫描</button>
        </div>
    </div>

    <div id="pluginList" class="row g-3"></div>

    <!-- 错误详情 Modal -->
    <div class="modal fade" id="pluginErrorModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">插件错误详情</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <pre id="pluginErrorDetail" class="small bg-light p-2 rounded" style="white-space:pre-wrap;word-break:break-word;"></pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">关闭</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        async function loadPlugins(){
            const el = document.getElementById('pluginList');
            el.replaceChildren();

            try{
                const resp = await fetch('/api/plugins');
                if(!resp.ok) throw new Error('获取插件失败：' + resp.status);
                const payload = await resp.json();

                const plugins = payload.plugins || payload.Plugins || [];
                const errors = payload.errors || payload.Errors || [];
                const errorsDetailed = payload.errorsDetailed || payload.ErrorsDetailed || [];

                // render plugins
                for(const p of plugins){
                    const col = document.createElement('div');
                    col.className = 'col-12';
                    const card = document.createElement('div');
                    card.className = 'card';
                    const body = document.createElement('div');
                    body.className = 'card-body d-flex justify-content-between align-items-start';

                    const meta = document.createElement('div');
                    const title = document.createElement('div');
                    title.className = 'fw-semibold';
                    title.textContent = (p.name || p.Name) + ' (' + (p.id || p.Id) + ')';
                    meta.appendChild(title);
                    const descText = p.description || p.Description;
                    if(descText){
                        const desc = document.createElement('div');
                        desc.className='text-muted small';
                        desc.textContent = descText;
                        meta.appendChild(desc);
                    }

                    const actions = document.createElement('div');
                    const controls = p.controls || p.Controls || [];
                    if(controls.length){
                        for(const c of controls){
                            const btn = document.createElement('button');
                            btn.type='button';
                            btn.className='btn btn-sm btn-outline-primary me-1';
                            btn.textContent = c.name || c.Name;
                            btn.addEventListener('click', async ()=>{
                                try{ await postJson('/Browser/ControlPlugin',{ pluginId:p.id || p.Id, command:c.command || c.Command }); await loadPlugins(); }
                                catch(e){ alert(e.message || '操作失败'); }
                            });
                            actions.appendChild(btn);
                        }
                    }

                    const functions = p.functions || p.Functions || [];
                    if(functions.length){
                        for(const f of functions){
                            const btn = document.createElement('button');
                            btn.type='button';
                            btn.className='btn btn-sm btn-outline-secondary ms-1';
                            btn.textContent = f.name || f.Name;
                            btn.addEventListener('click', async ()=>{
                                try{ await postJson('/Browser/RunPluginFunction',{ pluginId:p.id || p.Id, functionId:f.id || f.Id }); }
                                catch(e){ alert(e.message || '执行失败'); }
                            });
                            actions.appendChild(btn);
                        }
                    }

                    body.appendChild(meta);
                    body.appendChild(actions);
                    card.appendChild(body);
                    col.appendChild(card);
                    el.appendChild(col);
                }

                // render errors (summaries)
                for(const e of errors){
                    const col = document.createElement('div');
                    col.className='col-12';
                    const alert = document.createElement('div');
                    alert.className='alert alert-warning';
                    alert.textContent = e;
                    col.appendChild(alert);
                    el.appendChild(col);
                }

                // attach detail view triggers from detailed errors
                for(const d of errorsDetailed){
                    const col = document.createElement('div');
                    col.className='col-12';
                    const row = document.createElement('div');
                    row.className='d-flex gap-2 align-items-center mb-2';
                    const txt = document.createElement('div');
                    txt.className='text-muted small flex-grow-1';
                    txt.textContent = d.summary || d.Summary || d.assembly || d.Assembly || '插件加载错误';
                    const viewBtn = document.createElement('button');
                    viewBtn.type='button';
                    viewBtn.className='btn btn-sm btn-outline-danger';
                    viewBtn.textContent='详情';
                    viewBtn.addEventListener('click', ()=>{
                        document.getElementById('pluginErrorDetail').textContent = d.detail || d.Detail || '(无详细信息)';
                        const modal = new bootstrap.Modal(document.getElementById('pluginErrorModal'));
                        modal.show();
                    });
                    row.appendChild(txt);
                    row.appendChild(viewBtn);
                    col.appendChild(row);
                    el.appendChild(col);
                }

            }catch(ex){
                const elc = document.getElementById('pluginList');
                elc.innerHTML = '<div class="text-danger">加载插件目录失败：'+(ex.message||ex)+'</div>';
            }
        }

        document.getElementById('rescanBtn').addEventListener('click', ()=> loadPlugins());

        // minimal postJson helper
        async function postJson(url, body){
            const resp = await fetch(url, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body||{}) });
            if(!resp.ok){
                const txt = await resp.text();
                throw new Error(txt || resp.status);
            }
            return resp.json();
        }

        loadPlugins();
    </script>
}
