@{
    ViewData["Title"] = "Plugin Demo";
    Layout = "_Layout";
}

<h2>Plugin Demo: GetInstanceInfo</h2>

<form method="post" asp-controller="Browser" asp-action="PluginDemo">
    <div>
        <label>Plugin Id</label>
        <input name="PluginId" value="@ViewData["PluginId"] ?? "example.minimal"" />
    </div>
    <div>
        <label>Function Id</label>
        <input name="FunctionId" value="@ViewData["FunctionId"] ?? "GetInstanceInfo"" />
    </div>
    <div>
        <label>InstanceId (argument)</label>
        <input name="InstanceId" value="@ViewData["InstanceId"] ?? """ />
    </div>
    <div>
        <button type="submit">Call Plugin Function</button>
    </div>
</form>

@if (ViewData["ResultJson"] != null)
{
    <h3>Result (JSON)</h3>
    <pre>@ViewData["ResultJson"]</pre>
}

@if (ViewData["ResultData"] != null)
{
    var d = (dynamic)ViewData["ResultData"];
    <h3>Result Data</h3>
    <div>
        <p><strong>InstanceId:</strong> @d.InstanceId</p>
        <p><strong>DisplayName:</strong> @d.DisplayName</p>
        <p><strong>UserDataDirectory:</strong> @d.UserDataDirectory</p>
        <p><strong>OwnerId:</strong> @d.OwnerId</p>
        <p><strong>IsCurrent:</strong> @d.IsCurrent</p>
    </div>
}
