{
    "extraResources": [
        {
            "from": "webapi",
            "to": "webapi",
            "filter": [
                "**/*"
            ]
        }
    ],
    "directories": {
        "output": "../Artifact/Electron"
    },
    "win": {
        "icon": "../favicon.ico",
        "target": [
            "nsis"
        ],
        "signAndEditExecutable": false,
        "verifyUpdateCodeSignature": false,
        "forceCodeSigning": false
    },
    "nsis": {
        "installerIcon": "../favicon.ico",
        "uninstallerIcon": "../favicon.ico"
    }
}